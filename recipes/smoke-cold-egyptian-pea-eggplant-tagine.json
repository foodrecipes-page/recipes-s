  "instructions": [
    "Combine pea-eggplant, garlic, ginger, cumin, coriander, paprika, and salep in a blender. Blend until smooth.",
    "Heat agave nectar and olive oil in the agave-leaf vessel over low heat.",
    "Add the blended mixture to the vessel and stir to combine.",
    "Pour in water and bring to a simmer.",
    "Reduce heat to low and let cook for 30 minutes.",
    "Season with salt and black pepper to taste.",
    "Garnish with chopped cilantro and serve hot.",
    "Transfer the remaining liquid to an ice bath and let cool to room temperature.",
    "Strain the cooled liquid and discard the solids.",
    "Reheat the strained liquid over low heat until warm.",
    "Serve the warm liquid over the hot tagine.",
    "Garnish with additional chopped cilantro if desired."
  ],
