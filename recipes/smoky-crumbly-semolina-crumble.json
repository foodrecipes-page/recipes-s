  "ingredients": [
    {
      "name": "semolina",
      "amount": "1 cup"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup"
    },
    {
      "name": "cinnamon powder",
      "amount": "1/4 tsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1/8 tsp"
    },
    {
      "name": "vanilla extract",
      "amount": "1/2 tsp"
    },
    {
      "name": "unsalted butter",
      "amount": "3 tbsp, diced"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F (175°C).",
    "In a mixing bowl, combine semolina, coconut milk, cinnamon powder, smoked paprika, and vanilla extract. Mix well until no lumps remain.",
    "Pour the mixture onto a baking dish or a greased tray lined with parchment paper.",
    "Melt the unsalted butter in a small saucepan over medium heat. Pour this over the semolina layer once cooled slightly but still warm.",
    "Bake for about 20-25 minutes, until golden brown and crispy on top.",
    "Allow to cool before serving."
  ],
