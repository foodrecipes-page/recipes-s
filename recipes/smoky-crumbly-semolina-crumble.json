{
  "title": "Smoky Crumbly Semolina Crumble",
  "description": "A midnight craving Malaysian dish featuring a blend of semolina and broiling for added smokiness, suitable for those with fodmap sensitivities.",
  "cuisine": "Malaysian",
  "diet": [
    "vegetarian",
    "fodmap-friendly"
