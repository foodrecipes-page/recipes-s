{
  "title": "Spicy Tender Comfort Jamaican Tempeh Stir-fry",
  "description": "A comforting vegan dish with a spicy kick, perfect for a quick weeknight dinner.",
  "cuisine": "Jamaican",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "1 can of chickpeas",
      "amount": "drained and rinsed"
    },
    {
      "name": "4 ounces tempeh",
      "amount": "sliced thinly"
    },
    {
      "name": "2 tablespoons olive oil"
    },
    {
      "name": "1 medium onion",
      "amount": "finely chopped"
    },
    {
      "name": "3 cloves garlic",
      "amount": "minced"
    },
    {
      "name": "1 red pepper",
      "amount": "diced"
    },
    {
      "name": "1 teaspoon ground allspice"
    },
    {
      "name": "1 teaspoon curry powder"
    },
    {
      "name": "1/2 teaspoon smoked paprika"
    },
    {
      "name": "1/4 teaspoon cayenne pepper"
    },
    {
      "name": "salt and black pepper",
      "notes": "to taste"
    },
    {
      "name": "fresh cilantro leaves",
      "amount": "chopped for garnish"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add onions and garlic, sauté until translucent.",
    "Toss in diced red pepper and cook for an additional minute.",
    "Fold in tempeh slices, sprinkle with allspice, curry powder, smoked paprika, cayenne pepper, salt, and black pepper. Stir well to coat the tempeh evenly.",
    "Stir gently until tempeh is just heated through, about 2-3 minutes.",
    "Add chickpeas and cook for another minute, allowing flavors to meld together.",
    "Serve hot with fresh cilantro leaves as a garnish."
  ],
