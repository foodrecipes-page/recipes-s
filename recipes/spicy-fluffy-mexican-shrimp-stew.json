{
  "title": "Spicy Fluffy Mexican Shrimp Stew",
  "description": "A vibrant coconutladen shrimp stew with a hint of heat and a cloudlike texture, showcasing Mexican spices and creamy coconut milk.",
  "cuisine": "Mexican",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Shrimp, peeled and deveined",
      "amount": "1 lb (450 g)",
      "notes": "Freshly caught is best"
    },
    {
      "name": "Coconut milk, full fat",
      "amount": "2 cups (480 ml)",
      "notes": "Use canned for depth"
    },
    {
      "name": "Chicken or vegetable broth",
      "amount": "1 cup (240 ml)",
      "notes": "Low‑sodium preferred"
    },
    {
      "name": "Onion, finely diced",
      "amount": "1 medium (150 g)",
      "notes": "Roughly 1 cup"
    },
    {
      "name": "Garlic cloves, minced",
      "amount": "3 cloves",
      "notes": "About 1 tablespoon"
    },
    {
      "name": "Fresh green chilies, sliced",
      "amount": "2 (or 1 chipotle pepper, minced)",
      "notes": "Adjust heat to taste"
    },
    {
      "name": "Ground cumin",
      "amount": "1 teaspoon",
      "notes": "Adds earthy warmth"
    },
    {
      "name": "Smoked paprika",
      "amount": "1 teaspoon",
      "notes": "For a smoky depth"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon",
      "notes": "Adjust to taste"
    },
    {
      "name": "Fresh lime juice",
      "amount": "2 tablespoons (30 ml)",
      "notes": "Brightens the stew"
    },
    {
      "name": "Fresh cilantro, chopped",
      "amount": "¼ cup (20 g)",
      "notes": "For a fresh finish"
    },
    {
      "name": "Lime wedges, for serving",
      "amount": "2",
      "notes": ""
    },
    {
      "name": "Sweet potato, diced",
      "amount": "1 cup (120 g)",
      "notes": "Adds starch and sweetness"
    }
  ],
  "instructions": [
    "Heat 1 tablespoon olive oil in a large pot over medium heat.",
    "Add onion, garlic, and sliced green chilies; sauté until onion soft, about 5 minutes.",
    "Stir in ground cumin and smoked paprika, cooking for 1 minute until fragrant.",
    "Add diced sweet potato, stirring to lightly brown for 3 minutes.",
    "Pour in broth and coconut milk; bring to a gentle simmer, then reduce heat and let the stew reduce for 10 minutes until the sweet potato is tender.",
    "Increase heat to medium, add shrimp, and cook until pink and cooked through, about 5 minutes – watch closely to avoid overcooking.",
    "Season with salt and fresh lime juice, adjusting heat if needed.",
    "Stir in chopped cilantro, then remove from heat.",
    "Ladle the stew into bowls, garnish with lime wedges and extra cilantro.",
    "Serve hot, optionally over fluffy Mexican rice or as a standalone dish."
  ],
