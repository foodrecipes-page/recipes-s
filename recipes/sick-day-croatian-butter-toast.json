{
  "title": "Sick-Day Croatian Butter Toast",
  "description": "A comforting vegetarian-friendly sick-day dish featuring a decadent mix of butter, garlic, and Sriracha on fluffy bread.",
  "cuisine": "Croatian",
  "diet": [
    "vegetarian"
  ],
  "meal": "breakfast",
  "ingredients": [
