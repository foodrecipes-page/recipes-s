      "name": "bread slices",
      "amount": "8"
    },
    {
      "name": "butter",
      "amount": "1/2 cup"
    },
    {
      "name": "garlic cloves",
      "amount": "3-4"
    },
    {
      "name": "siracha sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "Lightly butter each bread slice and place on a baking sheet lined with parchment paper.",
    "Mince garlic cloves finely, then spread evenly over each slice of bread. Drizzle with sriracha sauce and sprinkle lightly with salt.",
    "Bake in preheated oven for 10-12 minutes or until the edges turn golden brown.",
    "Remove from oven and let cool slightly before serving."
  ],
