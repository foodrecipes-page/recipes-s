{
  "title": "Spicy Juicy Egyptian Oatmeal Fritters",
  "description": "Crispy, flavorful oat fritters with a zesty Egyptian kick, perfect for a lowcalorie, airfry breakfast or snack.",
  "cuisine": "Egyptian",
  "diet": [
    "low-calorie",
    "vegetarian"
  ],
