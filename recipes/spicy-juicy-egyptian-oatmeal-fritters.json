  "ingredients": [
    {
      "name": "rolled oats",
      "amount": "1 cup",
      "notes": "plain, no instant"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp",
      "notes": "for coating"
    },
    {
      "name": "egg",
      "amount": "1 large",
      "notes": "beaten"
    },
    {
      "name": "cucumber",
      "amount": "1/2 cup",
      "notes": "finely diced"
    },
    {
      "name": "tomato",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "precooked lentils",
      "amount": "2 tbsp",
      "notes": "optional for protein boost"
    },
    {
      "name": "ground cumin",
      "amount": "1/2 tsp",
      "notes": "ground or powder"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/4 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "fresh lemon juice",
      "amount": "1 tbsp",
      "notes": "freshly squeezed"
    },
    {
      "name": "parsley",
      "amount": "1 tbsp",
      "notes": "finely chopped"
    }
  ],
  "instructions": [
    "In a medium bowl combine the rolled oats, cumin, cayenne, and a pinch of salt.",
    "Add the beaten egg, diced cucumber, chopped tomato, lentils, and lemon juice; mix until the mixture is moist and holds together.",
    "Fold in the chopped parsley.",
    "Heat the air fryer to 375\u00b0F (190\u00b0C).",
    "Lightly brush or spray the basket with olive oil to prevent sticking.",
    "Drop tablespoon\u2011sized spoonfuls of the batter into the basket, spacing them about 1.5 inches apart.",
    "Air fry for 8 minutes, flipping halfway through, until the fritters are golden and crisp.",
    "Cool for a minute before removing; serve warm with a squeeze of lemon or a dollop of low\u2011fat yogurt.",
    "Repeat with remaining batter, adding a little oil as needed to maintain spacing."
  ],
