      "amount": "1/2 cup",
      "notes": "freshly squeezed"
    },
    {
      "name": "mixed seafood broth",
      "amount": "1/4 cup",
      "notes": "low-sodium"
    },
    {
      "name": "red onion",
      "amount": "1/2 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "ají amarillo pepper",
      "amount": "1",
      "notes": "seeded and finely chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "corn kernels",
      "amount": "1/2 cup",
      "notes": "fresh and cooked"
    },
    {
      "name": "bread flour",
      "amount": "2 tablespoons",
      "notes": "used for dusting"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Rinse the halibut fillets under cold water and pat them dry with paper towels",
    "Cut the halibut into small cubes and place them in a large bowl",
    "In a blender or food processor, puree the lime juice, mixed seafood broth, red onion, ají amarillo pepper, and garlic until smooth",
    "Pour the marinade over the fish cubes and toss to coat",
    "Cover the bowl with plastic wrap and refrigerate for at least 30 minutes to allow the fish to marinate",
    "After marinating, stir in the cooked corn kernels and season with salt and black pepper to taste",
    "Just before serving, dust the top of the ceviche with bread flour",
    "Serve the ceviche in small glasses or cups, garnished with additional lime wedges and corn kernels if desired"
  ],
