    {
      "name": "Corn Flour",
      "amount": "1 cup"
    },
    {
      "name": "Garlic Powder",
      "amount": "1 tablespoon"
    },
    {
      "name": "Paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "Red Pepper Flakes (Sriracha)",
      "amount": "2 tablespoons"
    },
    {
      "name": "Ground Beef or Chicken",
      "amount": "4 ounces"
    },
    {
      "name": "Onion, finely chopped",
      "amount": "1 medium"
    }
  ],
  "instructions": [
    "Preheat your oven to 375\u00b0F (190\u00b0C).",
    "Mix together corn flour and garlic powder in a large bowl.",
    "Add onion, paprika, red pepper flakes, and ground beef or chicken to the mixture. Knead until well combined.",
    "Form into patties about 1-inch thick and flatten slightly on both sides.",
    "Place on a baking sheet lined with parchment paper.",
    "Bake for 20 minutes or until golden brown and crispy on the outside.",
    "Remove from oven, let cool slightly, then serve warm."
  ],
