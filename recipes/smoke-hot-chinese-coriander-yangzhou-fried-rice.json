{
  "title": "Smoke-Hot Chinese Coriander Yangzhou Fried Rice",
  "description": "A light and flavorful Yangzhou-style fried rice dish featuring smoke-hot Sichuan pepper and fresh cilantro from Yunnan province. This halal-friendly recipe is easy to make and perfect for a quick weeknight dinner.",
  "cuisine": "Chinese",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Cooked rice",
      "amount": "2 cups",
      "notes": "preferably day-old rice"
    },
    {
      "name": "Vegetable oil",
      "amount": "2 tablespoons",
      "notes": "use for stir-frying"
    },
    {
      "name": "Ginger",
      "amount": "1 small piece",
      "notes": "about 1 inch in size"
    },
    {
      "name": "Garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "Sichuan peppercorns",
      "amount": "1 teaspoon",
      "notes": "whole, toasted, and ground"
    },
    {
      "name": "Smoked paprika",
      "amount": "1/2 teaspoon",
      "notes": "optional"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "Fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Scrambled eggs",
      "amount": "2",
      "notes": "beaten, cooked, and diced"
    },
    {
      "name": "Green onions",
      "amount": "2",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat 1 tablespoon of vegetable oil in a wok or large skillet over medium-high heat.",
    "Add the ginger and garlic and stir-fry until fragrant, about 30 seconds.",
    "Add the cooked rice, Sichuan peppercorns, smoked paprika, and salt. Stir-fry for 2-3 minutes, breaking up any clumps with a spatula.",
    "Make a well in the center of the rice mixture and add the beaten eggs. Scramble the eggs until cooked through, then mix into the rice.",
    "Stir in the chopped cilantro and green onions.",
    "Serve immediately, garnished with additional cilantro if desired."
  ],
