      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "bay leaf",
      "amount": "1",
      "notes": "optional"
    },
    {
      "name": "water",
      "amount": "2 cups",
      "notes": "for simmering"
    }
  ],
  "instructions": [
    "Heat olive oil in a medium pot over medium heat.",
    "Add onions and sauté until soft and translucent (about 5 minutes).",
    "Add garlic and smoked paprika; stir for 1 minute until fragrant.",
    "Add water and bay leaf (if using); bring to a gentle boil.",
    "Reduce heat to low, cover, and simmer for 15-20 minutes until onions are tender and stew is thickened.",
    "Remove bay leaf and serve."
