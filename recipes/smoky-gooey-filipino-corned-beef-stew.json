{
  "title": "Smoky Gooey Filipino Corned Beef Stew",
  "description": "A lazy‑Sunday Filipino stew where canned corned beef meets smoky spices and creamy coconut milk for a velvety, fermented‑flavored comfort dish.",
  "cuisine": "Filipino",
  "diet": [
    "nut-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "canned corned beef (400g, drained)",
      "amount": "1 can (400 g)",
      "notes": "retain juice for extra flavor"
    },
    {
      "name": "onion, diced",
      "amount": "1 medium",
      "notes": "adds sweetness"
    },
    {
      "name": "garlic cloves, minced",
      "amount": "2",
      "notes": "fresh"
    },
    {
      "name": "smoked paprika",
      "amount": "1 Tbsp",
      "notes": "for smokiness"
    },
    {
      "name": "liquid smoke",
      "amount": "1 tsp",
      "notes": "subtle smoke flavor"
    },
    {
      "name": "fermented soy sauce (kikkoman)",
      "amount": "1 Tbsp",
      "notes": "adds umami and salt"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup (240 ml)",
      "notes": "creates gooey, creamy texture"
    },
    {
      "name": "water",
      "amount": "1 cup (240 ml)",
      "notes": "adjust consistency"
    },
    {
      "name": "tomato paste",
      "amount": "2 Tbsp",
      "notes": "deepens color and flavor"
    },
    {
      "name": "brown sugar",
      "amount": "1 Tbsp",
      "notes": "balances acidity"
    },
    {
      "name": "vegetable oil",
      "amount": "1 Tbsp",
      "notes": "for sautéing"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp",
      "notes": "freshly ground"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large pot over medium heat.",
    "Add the diced onion and minced garlic; sauté until translucent, about 3 minutes.",
    "Pour in the canned corned beef with its juices and stir to combine.",
    "Add the smoked paprika, liquid smoke, fermented soy sauce, black pepper, and brown sugar; cook for 2 minutes to let the spices bloom.",
    "Stir in the coconut milk and water, then add the tomato paste; bring the mixture to a gentle simmer.",
    "Simmer uncovered for 15–20 minutes, or until the sauce thickens and the flavors meld; keep the temperature around 165 °F (74 °C) for safe food handling.",
    "Taste and adjust seasoning with additional salt, soy sauce, or sugar if desired.",
    "Serve hot over steamed rice or with crusty bread.",
    "Clean up the pot and enjoy a comforting, smoky, nut‑free stew perfect for a lazy Sunday."
  ],
