{
  "title": "Smoky Gooey Filipino Corned Beef Stew",
  "description": "A lazySunday Filipino stew where canned corned beef meets smoky spices and creamy coconut milk for a velvety, fermentedflavored comfort dish.",
  "cuisine": "Filipino",
  "diet": [
    "nut-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "canned corned beef (400g, drained)",
      "amount": "1 can (400\u202fg)",
      "notes": "retain juice for extra flavor"
    },
    {
      "name": "onion, diced",
      "amount": "1 medium",
      "notes": "adds sweetness"
    },
    {
      "name": "garlic cloves, minced",
      "amount": "2",
      "notes": "fresh"
    },
    {
      "name": "smoked paprika",
      "amount": "1\u202fTbsp",
      "notes": "for smokiness"
    },
    {
      "name": "liquid smoke",
      "amount": "1\u202ftsp",
      "notes": "subtle smoke flavor"
    },
    {
      "name": "fermented soy sauce (kikkoman)",
      "amount": "1\u202fTbsp",
      "notes": "adds umami and salt"
    },
    {
      "name": "coconut milk",
      "amount": "1\u202fcup (240\u202fml)",
      "notes": "creates gooey, creamy texture"
    },
    {
      "name": "water",
      "amount": "1\u202fcup (240\u202fml)",
      "notes": "adjust consistency"
    },
    {
      "name": "tomato paste",
      "amount": "2\u202fTbsp",
      "notes": "deepens color and flavor"
    },
    {
      "name": "brown sugar",
      "amount": "1\u202fTbsp",
      "notes": "balances acidity"
    },
    {
      "name": "vegetable oil",
      "amount": "1\u202fTbsp",
      "notes": "for saut\u00e9ing"
    },
    {
      "name": "black pepper",
      "amount": "1/4\u202ftsp",
      "notes": "freshly ground"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large pot over medium heat.",
    "Add the diced onion and minced garlic; saut\u00e9 until translucent, about 3\u202fminutes.",
    "Pour in the canned corned beef with its juices and stir to combine.",
    "Add the smoked paprika, liquid smoke, fermented soy sauce, black pepper, and brown sugar; cook for 2\u202fminutes to let the spices bloom.",
    "Stir in the coconut milk and water, then add the tomato paste; bring the mixture to a gentle simmer.",
    "Simmer uncovered for 15\u201320\u202fminutes, or until the sauce thickens and the flavors meld; keep the temperature around 165\u202f\u00b0F (74\u202f\u00b0C) for safe food handling.",
    "Taste and adjust seasoning with additional salt, soy sauce, or sugar if desired.",
    "Serve hot over steamed rice or with crusty bread.",
    "Clean up the pot and enjoy a comforting, smoky, nut\u2011free stew perfect for a lazy Sunday."
  ],
