    {
      "name": "raw frozen prawns",
      "amount": "1 pound",
      "notes": "thawed"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chopped fresh parsley",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Heat the olive oil in the iron-teppan vessel over medium heat.",
    "Add the chopped onion and cook until it is caramelized, stirring occasionally.",
    "Add the minced garlic and cook for 1 minute, stirring constantly.",
    "Add the thawed prawns and cook until they are pink and fully cooked, stirring occasionally.",
    "Add the tomato paste, honey, lemon juice, salt, and black pepper, and stir to combine.",
    "Reduce the heat to low and simmer the mixture for 5 minutes, stirring occasionally.",
    "Stir in the chopped fresh parsley.",
    "Serve the tagine hot, garnished with additional parsley if desired."
  ],
