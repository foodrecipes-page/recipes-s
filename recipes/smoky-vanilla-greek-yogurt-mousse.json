  "ingredients": [
    {
      "name": "Plain low\u2011fat Greek yogurt",
      "amount": "1 cup (245 g)",
      "notes": "low\u2011fat"
    },
    {
      "name": "Heavy cream",
      "amount": "1/2 cup (118 ml)"
    },
    {
      "name": "Honey, raw",
      "amount": "2 tbsp (30 g)"
    },
    {
      "name": "Vanilla extract",
      "amount": "1 tsp (5 ml)"
    },
    {
      "name": "Smoked sea salt",
      "amount": "1/4 tsp"
    },
    {
      "name": "Smoked paprika",
      "amount": "1/4 tsp",
      "notes": "adds smoky flavor"
    },
    {
      "name": "Fresh lemon juice",
      "amount": "1 tsp (5 ml)"
    }
  ],
  "instructions": [
    "Combine Greek yogurt, lemon juice, and vanilla extract in a medium bowl.",
    "Whisk until the mixture is smooth and creamy.",
    "Gradually whisk in honey until fully dissolved.",
    "Add smoked sea salt and smoked paprika, stirring to combine.",
    "In a separate bowl, whisk heavy cream until soft peaks form.",
    "Gently fold the whipped cream into the yogurt mixture until well blended.",
    "Divide mousse into four serving glasses or bowls.",
    "Refrigerate for at least 30 minutes to set and chill.",
    "Optional: Sprinkle chopped pistachios on top before serving as garnish.",
    "Serve chilled.",
    ""
