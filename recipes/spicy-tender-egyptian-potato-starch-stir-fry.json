{
  "title": "Spicy Tender Egyptian Potato Starch Stir-fry",
  "description": "This kid-friendly vegan dish features tender potatoes cooked in a spicy sauce using potato starch for a unique texture and taste.",
  "cuisine": "Egyptian",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "potatoes",
      "amount": "1 (200g) potato, diced"
    },
    {
      "name": "onions",
      "amount": "1 onion, finely chopped"
    },
    {
      "name": "garlic cloves",
      "amount": "4 garlic cloves, minced"
    },
    {
      "name": "chili flakes",
      "amount": "1 tsp"
    },
    {
      "name": "tomato paste",
      "amount": "2 tbsp"
    },
    {
      "name": "soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "water",
      "amount": "3 cups"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "fresh cilantro",
      "amount": "handful, chopped (optional)"
    },
    {
      "name": "fresh lime juice",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Heat oil in a pan over medium heat. Add onions and cook until translucent.",
    "Add garlic and chili flakes to the pan and sauté for about 30 seconds, stirring constantly to prevent burning.",
    "Stir in tomato paste and cook for another minute until fragrant.",
    "Pour in soy sauce and water, stir well to combine. Increase heat to bring to a simmer.",
    "Add diced potatoes to the pot, reduce heat to low-medium and cover with a lid. Cook for about 15 minutes or until potatoes are tender.",
    "Stir in salt and fresh lime juice before serving. Garnish with chopped cilantro if desired."
  ],
