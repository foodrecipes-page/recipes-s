      "name": "salmon fillets",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "brown sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1 tablespoon"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    }
  ],
  "instructions": [
    "Preheat the grill to medium high heat.",
    "In a small bowl, mix together smoked paprika, brown sugar, salt, and black pepper.",
    "Add the lemon juice and olive oil to the bowl and stir until a smooth paste forms.",
    "Add the garlic to the bowl and mix well.",
    "Thread the salmon pieces onto skewers.",
    "Brush the skewers with the smoky paste.",
    "Grill the skewers for 8 minutes per side.",
    "Let the skewers rest for 2 minutes before serving."
  ],
