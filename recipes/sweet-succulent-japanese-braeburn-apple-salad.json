{
  "title": "Sweet Succulent Japanese Braeburn Apple Salad",
  "description": "A light and refreshing Japanese salad featuring Braeburn apples, kombu cold extract, and a floral touch, perfect for a satvik friendly meal.",
  "cuisine": "Japanese",
  "diet": [
    "vegetarian"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Braeburn apples",
      "amount": "2 large",
      "notes": "peeled and diced"
    },
    {
      "name": "kombu cold extract",
      "amount": "2 tablespoons"
    },
    {
      "name": "sesame seeds",
      "amount": "1 tablespoon"
    },
    {
      "name": "pickled ginger",
      "amount": "1/4 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "shiso leaves",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "rice vinegar",
      "amount": "1 tablespoon"
    },
    {
      "name": "honey",
      "amount": "1 teaspoon"
    },
    {
      "name": "toasted almonds",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "In a large bowl, whisk together kombu cold extract, rice vinegar, and honey until well combined.",
    "Add the diced Braeburn apples to the bowl and toss to coat with the dressing.",
    "In a small pan, toast the sesame seeds over medium heat until fragrant and lightly browned.",
    "Sprinkle the toasted sesame seeds over the apple mixture and toss to combine.",
    "Add the chopped shiso leaves and pickled ginger to the bowl and toss gently.",
    "Top the salad with chopped toasted almonds and serve immediately.",
    "Garnish with additional shiso leaves and pickled ginger if desired.",
    "Serve chilled or at room temperature."
  ],
