  "ingredients": [
    {
      "name": "1 lb of fresh clams",
      "amount": "lb"
    },
    {
      "name": "3 tablespoons of vegetable oil",
      "amount": "tbsp"
    },
    {
      "name": "1 small onion, chopped",
      "amount": null
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": "cloves"
    },
    {
      "name": "1/4 cup of soy sauce",
      "amount": "cup"
    },
    {
      "name": "1 tablespoon of oyster sauce or Worcestershire sauce",
      "amount": "tbsp"
    },
    {
      "name": "1/2 teaspoon of salt",
      "amount": "tsp"
    },
    {
      "name": "Juice of 1 lime",
      "amount": null
    },
    {
      "name": "Freshly chopped cilantro for garnish (optional)",
      "amount": null
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a wok or large skillet over medium-high heat.",
    "Add the onions and garlic, cooking until they are translucent and fragrant.",
    "Pour in the clams, add soy sauce, oyster sauce/lime juice, salt, and stir well to combine all ingredients.",
    "Cook for about 5-7 minutes, or until the clams have opened. Discard any unopened clams.",
    "Garnish with fresh cilantro if using."
