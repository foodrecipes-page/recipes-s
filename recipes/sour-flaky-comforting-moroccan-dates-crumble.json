      "amount": "2 tablespoons"
    },
    {
      "name": "Rosemary Sprigs",
      "amount": "1 tablespoon fresh or 1 teaspoon dried"
    },
    {
      "name": "Salt",
      "amount": "Pinch"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a mixing bowl, combine dates, flour, sugar, oil, rosemary, and salt.",
