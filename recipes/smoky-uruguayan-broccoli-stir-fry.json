      "name": "Purple Sprouting Broccoli",
      "amount": "1 head",
      "notes": "Washed and chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Chopped finely"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "Chopped finely"
    },
    {
      "name": "Red Bell Pepper",
      "amount": "1 large",
      "notes": "Sliced thinly"
    },
    {
      "name": "Thyme Leaves",
      "amount": "2 tablespoons",
      "notes": "Fresh, finely chopped"
    },
    {
      "name": "Smoked Paprika Powder",
      "amount": "½ teaspoon",
      "notes": ""
    },
    {
      "name": "Dried Oregano",
      "amount": "¼ teaspoon",
      "notes": "Optional for extra smokiness"
    },
    {
      "name": "Nutritional Yeast Flakes",
      "amount": "1 tablespoon",
      "notes": "For added umami and texture"
    },
    {
      "name": "Extra Virgin Olive Oil",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "Water or Broth",
      "amount": "½ cup",
      "notes": "Optional for thinning the sauce if needed"
    },
    {
      "name": "Salt",
      "amount": "To taste",
      "notes": ""
    }
  ],
  "instructions": [
    "Heat oil in a large skillet over medium-high heat.",
    "Add garlic and onion, sautéing until translucent.",
    "Stir in red bell pepper and cook for another minute.",
    "Fold in chopped purple sprouting broccoli head and toss to coat with oil.",
    "Season with thyme leaves, smoked paprika powder, dried oregano (if using), and salt. Stir gently but thoroughly.",
    "Pour in water or broth if necessary to prevent sticking and create a sauce-like consistency.",
    "Reduce heat to medium-low and let the mixture cook for about 10 minutes until broccoli is tender yet crisp.",
    "Sprinkle nutritional yeast flakes over the top just before serving, allowing it to caramelize slightly.",
    "Serve hot."
  ],
