{
  "title": "Smoky Uruguayan Broccoli Stir-fry",
  "description": "A floral and dense monsoon dish from Uruguay featuring purple sprouting broccoli with a smoky touch made dairy-free.",
  "cuisine": "Uruguayan",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
