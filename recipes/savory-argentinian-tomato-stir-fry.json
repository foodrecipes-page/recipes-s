      "amount": "3-4 pieces"
    },
    {
      "name": "onions",
      "amount": "1 medium"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "Slice tomatoes and onions, finely chop garlic.",
    "Combine red pepper paste with olive oil in a bowl. Add chopped garlic and mix well.",
    "Add sliced onions into the sauce, stir for about 2 minutes until translucent.",
    "Add chopped tomatoes and dumplings to the sauce mixture, cover and simmer for 5-7 minutes or until dumplings are cooked.",
    "Serve hot as a lunch meal."
