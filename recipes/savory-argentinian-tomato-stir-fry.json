{
  "title": "Savory Argentinian Tomato Stir-fry",
  "description": "A kid-friendly and low-calorie friendly savory dish featuring red pepper paste, tomatoes, and dumplings in a flavorful yet mild sauce.",
  "cuisine": "Argentine",
