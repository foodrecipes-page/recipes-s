{
  "title": "Sweet Flaky Middle Eastern Egg Ouzi",
  "description": "A sweet and flaky Middle Eastern dish featuring free-range eggs, perfect for a sick day, made in a claypot and free from nuts.",
  "cuisine": "Middle Eastern",
  "diet": [
    "vegetarian"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "free-range eggs",
      "amount": "4 large",
      "notes": "beaten"
    },
    {
      "name": "all-purpose flour",
      "amount": "1 cup"
    },
    {
      "name": "granulated sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "unsalted butter",
      "amount": "1/4 cup",
      "notes": "melted"
    },
    {
      "name": "rose water",
      "amount": "1 tablespoon"
    },
    {
      "name": "orange blossom water",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "water",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, whisk together the flour, sugar, and salt.",
    "In a separate bowl, whisk together the melted butter, rose water, and orange blossom water.",
    "Add the wet ingredients to the dry ingredients and stir until just combined.",
    "Fold in the beaten eggs until the mixture is smooth.",
    "Pour the mixture into a claypot and add the water.",
    "Cover the claypot with a lid and bake for 25 minutes.",
    "Remove the lid and continue baking for an additional 10 minutes, or until the top is golden brown."
  ],
