{
  "title": "Simple Steamed Canadian Salt Cod Pilaf",
  "description": "A light and quick-fix Canadian dish featuring salt cod, this pilaf is umami and ovo-vegetarian-friendly. It is made with mushimono-steam method for a healthy twist.",
  "cuisine": "Canadian",
  "diet": [
    "ovo-vegetarian"
  ],
