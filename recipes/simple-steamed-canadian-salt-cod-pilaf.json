  "ingredients": [
    {
      "name": "salt cod",
      "amount": "1 pound",
      "notes": "soaked overnight and drained"
    },
    {
      "name": "white rice",
      "amount": "2 cups"
    },
    {
      "name": "water",
      "amount": "4 cups"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and grated"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Rinse the soaked salt cod and cut it into small pieces.",
    "In a large bowl, combine the rice, water, carrots, onion, garlic, olive oil, salt, and black pepper.",
    "Add the cut salt cod to the bowl and mix well.",
    "Transfer the mixture to a steamer basket lined with parchment paper.",
    "Steam the mixture over boiling water for 15 minutes.",
    "Fluff the pilaf with a fork and serve hot.",
    "Garnish with chopped fresh parsley if desired.",
    "Serve immediately and enjoy.",
    "Refrigerate or freeze leftovers for later use."
  ],
