      "amount": "1/2 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "use a light hand"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "all-purpose flour",
      "amount": "2 tablespoons"
    },
    {
      "name": "beef broth",
      "amount": "1 cup"
    },
    {
