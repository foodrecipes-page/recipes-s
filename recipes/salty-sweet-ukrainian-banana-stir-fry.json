      "amount": "1 tablespoon"
    },
    {
      "name": "chopped walnuts",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Heat coconut oil in a large skillet over medium heat.",
    "Add chopped onion and cook until translucent, about 3 minutes.",
    "Add minced garlic and grated ginger and cook for 1 minute.",
    "Add sliced bananas and cook for 2 minutes on each side, until golden brown.",
    "Add turmeric, salt, and black pepper, and stir to combine.",
    "Add honey and stir to combine, cooking for an additional minute.",
    "Stir in chopped walnuts and cook for 1 minute.",
    "Remove from heat and serve warm."
  ],
