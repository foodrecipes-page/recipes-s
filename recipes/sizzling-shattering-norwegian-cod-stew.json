{
  "title": "Sizzling Shattering Norwegian Cod Stew",
  "description": "A bold, mustard-infused cod stew with Sichuan pepper, simmered in a copper mug for a dramatic, date-night finish.",
  "cuisine": "Norwegian",
  "diet": [
    "nut-free"
  ],
