      "name": "Eggs",
      "amount": "4"
    },
    {
      "name": "Sugared Brown Sugar Syrup",
      "amount": "1/2 cup"
    },
    {
      "name": "Water",
      "amount": "3/4 cup"
    },
    {
      "name": "Flour",
      "amount": "1 tablespoon"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Place eggs in a sous-vide water bath at 65°C for about an hour.",
    "Let the eggs cool and then peel them. Cut into small pieces.",
    "Combine sugar syrup, water, flour, and salt in a saucepan over medium heat.",
    "Bring to a boil, stirring continuously until thickened.",
    "Fold egg mixture into sweet and dense sauce.",
    "Garnish with fresh herbs if desired."
  ],
