{
  "title": "Smoky Tender Filipino Cabbage Skewers",
  "description": "Tender hepsi sweetheart cabbage marinated in a smoky, sweet‑savory blend and grilled to perfection, perfect for a solo vegan dinner.",
  "cuisine": "Filipino",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "hepsi sweetheart cabbage",
      "amount": "1 medium head",
      "notes": "cut into 1‑inch thick wedges"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon",
      "notes": "for brushing"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon",
      "notes": "use low‑sodium if preferred"
    },
    {
      "name": "miso paste",
      "amount": "1 tablespoon",
      "notes": "white or yellow miso"
    },
    {
      "name": "maple syrup",
      "amount": "1 tablespoon",
      "notes": "acts as sweetener"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon",
      "notes": "for smoky flavor"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon",
      "notes": ""
    },
    {
      "name": "salt",
      "amount": "½ teaspoon",
      "notes": ""
    },
    {
      "name": "black pepper",
      "amount": "¼ teaspoon",
      "notes": ""
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    }
  ],
  "instructions": [
    "Preheat a grill or a hot skillet (or use a tandoor‑style grill if available) to medium‑high heat.",
    "In a bowl, whisk together olive oil, soy sauce, miso paste, maple syrup, smoked paprika, cumin, salt, pepper, and lime juice to create the glaze.",
    "Gently toss the cabbage wedges in the glaze, ensuring each piece is evenly coated.",
    "Thread the glazed cabbage onto skewers, packing them loosely so the heat can circulate.",
    "Brush the skewers with a little extra glaze before grilling.",
    "Grill the skewers for 4–6 minutes per side, or until the cabbage edges are slightly charred and the vegetables are tender.",
    "Remove from heat, let rest for 2 minutes, then serve warm."
  ],
