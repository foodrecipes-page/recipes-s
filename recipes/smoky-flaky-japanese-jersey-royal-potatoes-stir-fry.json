    },
    {
      "name": "Garlic cloves",
      "amount": "3-4, minced"
    },
    {
      "name": "Water or bone broth",
      "amount": "1 cup"
    },
    {
      "name": "Vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Smoked Paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Lemon Juice",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "Wash and peel the Jersey Royal Potatoes. Slice them into thin rounds, about 1/8-inch thick.",
    "Drain any excess water from potatoes if using bone broth or water as a liquid. Add to a baking dish with minced garlic and lemon juice.",
    "Sprinkle smoked paprika over potatoes evenly and toss to coat.",
    "Roast in the preheated oven for about 20-25 minutes, until golden brown and crispy on the edges.",
    "Serve hot or at room temperature as a snack."
  ],
