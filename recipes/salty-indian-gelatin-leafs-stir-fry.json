{
  "title": "Salty Indian Gelatin Leafs Stir-fry",
  "description": "A diabetic-friendly snack with a unique blend of crispy gelatin leaves, aromatic tadka and savory spices to satisfy your midnight craving.",
  "cuisine": "Indian",
  "diet": [
    "diabetic-friendly"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Gelatin Leaves",
      "amount": "5-10 sheets"
    },
    {
      "name": "Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Mustard Seeds",
      "amount": "a pinch"
    },
    {
      "name": "Urad Dal (Chickpea Flours)",
      "amount": "1 tablespoon"
    },
    {
      "name": "Garam Masala Powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Turmeric Powder",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "In a small pan, heat oil and add mustard seeds. Once they start spluttering, add urad dal and saut\u00e9 for about 30 seconds.",
    "Add garam masala powder and turmeric powder to the pan, stirring continuously until fragrant and spices release their flavors (about 15-20 seconds).",
    "Gently fold in gelatin leaves into the tadka. Stir gently so as not to break up the leaves. Cook for about 3 minutes or until heated through.",
    "Serve immediately while hot."
  ],
