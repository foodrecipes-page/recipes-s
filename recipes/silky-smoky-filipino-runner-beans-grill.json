{
  "title": "Silky Smoky Filipino Runner Bean Grill",
  "description": "A fragrant, silky grilled runner bean dish infused with lemongrass, ginger, and a smoky hint of roasted coconut, perfect for a FODMAP-friendly Filipino feast.",
  "cuisine": "Filipino",
  "diet": [
    "fodmap-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "runner beans",
      "amount": "500 g",
      "notes": "trimmed and washed"
    },
    {
      "name": "fresh ginger",
      "amount": "2.5 cm piece",
      "notes": "thinly sliced"
    },
    {
      "name": "lemongrass",
      "amount": "2 stalks",
      "notes": "pounded and sliced"
    },
    {
      "name": "fish sauce",
      "amount": "2 tbsp",
      "notes": "low-sodium if possible"
    },
    {
      "name": "low-sodium soy sauce",
      "amount": "1 tbsp",
      "notes": "tamari or gluten-free soy sauce"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "for brushing"
    },
    {
      "name": "coconut oil",
      "amount": "1 tbsp",
      "notes": "for added smokiness"
    },
    {
      "name": "roasted coconut flakes",
      "amount": "1/4 cup",
      "notes": "to sprinkle after grilling"
    },
    {
      "name": "toasted sesame seeds",
      "amount": "1 tbsp",
      "notes": "for garnish"
    },
    {
      "name": "lime zest and juice",
      "amount": "1 lime",
      "notes": "zest + 1 tbsp juice"
    },
    {
      "name": "salt",
      "amount": "to taste",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat grill to medium-high (about 200°C).",
    "In a small bowl, whisk together fish sauce, soy sauce, olive oil, coconut oil, lime juice, and a pinch of salt.",
    "Pat runner beans dry; drizzle with half the sauce mixture and toss to coat.",
    "Place ginger and lemongrass slices on the grill; cook 1–2 minutes until fragrant, then remove.",
    "Arrange beans on grill; cook 3–4 minutes per side, brushing with remaining sauce, until charred and tender.",
    "During the last minute, sprinkle roasted coconut flakes over beans to toast lightly.",
    "Remove beans; squeeze lime zest over them and toss gently.",
    "Transfer to serving platter; garnish with toasted sesame seeds and leftover ginger‑lemongrass slices. Serve immediately, optionally with steamed rice or quinoa."
  ],
