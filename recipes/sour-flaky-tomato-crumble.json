{
  "title": "Sour Flaky Tomato Crumble",
  "description": "A brunch-mood Venezuelan dish featuring a vegan butter-based crumble with sour tomatoes and spices, perfect for those on keto-friendly diets.",
  "cuisine": "Venezuelan",
  "diet": [
    "vegan",
    "keto"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Vegan butter",
      "amount": "1/2 cup"
    },
    {
      "name": "All-purpose flour",
      "amount": "1 cup"
    },
    {
      "name": "Xylitol (a natural sweetener)",
      "amount": "3 tablespoons"
    },
    {
      "name": "Bhuna masala powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Paprika",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Sour tomatoes (e.g., cherry tomatoes)",
      "amount": "6 fresh"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F.",
    "Mix flour, xylitol, bhuna masala powder, salt, and paprika in a bowl until well combined.",
    "Drizzle vegan butter into the dry mixture and mix it with your hands or a fork until you get a dough-like consistency.",
    "Gently fold in sliced sour tomatoes.",
    "Transfer the crumble mixture onto a baking sheet lined with parchment paper. Press to form a crust shape if desired.",
    "Bake for 20-25 minutes, or until golden brown and crispy on top.",
    "Serve immediately as a dessert or snack."
  ],
