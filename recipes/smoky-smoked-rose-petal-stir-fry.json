{
  "title": "Smoky Smoked Rose Petal Stir-Fry",
  "description": "A smoky and creamy Moroccan-inspired brunch dish featuring rose water with a touch of garlic and lemon for added flavor.",
  "cuisine": "Moroccan",
  "diet": null,
  "meal": "brunch",
  "ingredients": [
    {
      "name": "1 cup smoked salmon fillets",
      "amount": "pieces"
    },
    {
      "name": "2 tablespoons olive oil",
      "notes": "for smoking and stir-frying"
    },
    {
      "name": "4 cups baby spinach leaves",
      "amount": "packed"
    },
    {
      "name": "3 cloves garlic, minced",
      "notes": "adjust to taste"
    },
    {
      "name": "1 lemon, juiced",
      "amount": "full"
    },
    {
      "name": "2 tablespoons rose water",
      "amount": "ready-to-use"
    },
    {
      "name": "1/4 cup heavy cream",
      "amount": "ready-to-serve"
    },
    {
      "name": "Pinch of salt and pepper",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium-high heat.",
    "Add smoked salmon pieces, garlic, and lemon juice. Cook for about 3 minutes until fish is partially cooked.",
    "Stir in rose water and heavy cream. Add baby spinach leaves and cook until they wilt and the sauce thickens.",
    "Season with salt and pepper to taste.",
    "Serve hot as a brunch dish."
  ],
