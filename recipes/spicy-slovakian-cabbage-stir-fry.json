    {
      "name": "1/4 tsp cayenne pepper",
      "amount": ""
    },
    {
      "name": "Juice of 1 lemon",
      "amount": ""
    },
    {
      "name": "2 cloves garlic, minced",
      "amount": ""
    },
    {
      "name": "1 tbsp apple cider vinegar",
      "amount": ""
    }
  ],
  "instructions": [
    "Heat olive oil in a pan over medium heat.",
    "Add shredded cabbage and sauté for about 5 minutes until wilted.",
    "Stir in smoked paprika, cayenne pepper, minced garlic, and lemon juice. Cook for another minute to meld the flavors.",
    "Drizzle apple cider vinegar over the mixture and stir quickly to distribute evenly across the cabbage.",
    "Serve hot as a side dish or lightly drizzled on scrambled eggs."
