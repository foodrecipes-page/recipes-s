      "amount": "1/4 teaspoon"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt to taste",
      "amount": ""
    },
    {
      "name": "Halal-friendly croutons (optional)",
      "amount": "2 tablespoons, for garnish"
    }
  ],
  "instructions": [
    "Preheat the oven to 350°F.",
    "In a large bowl, mix together the chopped ancho peppers, garlic, sun-dried tomatoes (if using), cayenne pepper flakes, and olive oil. Season with salt as needed.",
    "Press the mixture into the bottom of a lightly greased 8x8 inch baking dish.",
    "If using croutons, sprinkle them evenly over the top of the filling.",
    "Bake in the preheated oven for about 25 minutes or until golden brown and crisp on top.",
    "Remove from heat and let cool before serving."
