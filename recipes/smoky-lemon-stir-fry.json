    },
    {
      "name": "2 cloves garlic",
      "amount": "minced"
    },
    {
      "name": "1 can (500ml) coconut milk"
    },
    {
      "name": "Juice of 3 lemons"
    },
    {
      "name": "1/4 cup lemon juice concentrate"
    },
    {
      "name": "1 tablespoon olive oil"
    },
    {
      "name": "Salt and pepper",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add onions and garlic, cooking until softened about 5 minutes.",
    "Pour in coconut milk, lemon juice, lemon concentrate, stir well to combine, then add salt and pepper.",
    "Simmer for another 10 minutes or until slightly thickened.",
    "Serve hot as a main dish."
