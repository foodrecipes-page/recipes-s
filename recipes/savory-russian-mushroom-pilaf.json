      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "rice",
      "amount": "2 cups",
      "notes": "uncooked white or brown"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
