  "instructions": [
    "Heat oil in a large skillet over medium heat",
    "Add chopped onion and cook until softened",
    "Add minced garlic and cook for 1 minute",
    "Add mushrooms and cook until they release their liquid and start to brown",
    "Add Sichuan pepper and stir to combine",
    "Add lacquer glaze and stir to combine",
    "Add rice to the skillet and stir to combine with the mushroom mixture",
    "Add 4 cups of water to the skillet and bring to a boil",
    "Reduce heat to low, cover, and simmer for 20 minutes"
  ],
