      "name": "1 lb (450g) king prawns",
      "amount": "1 lb (450g)",
      "notes": "Shell and de-vein"
    },
    {
      "name": "2 tablespoons olive oil",
      "amount": "2 tbsp",
      "notes": "Extra virgin for flavor"
    },
    {
      "name": "1 small onion, finely chopped",
      "amount": "1 small",
      "notes": ""
    },
    {
      "name": "4 cloves garlic, minced",
      "amount": "4 cloves",
      "notes": ""
    },
    {
      "name": "Juice of 1 lemon",
      "amount": "Juice of 1",
      "notes": "For added brightness"
    },
    {
      "name": "2 tablespoons soy sauce (or tamari for vegan)",
      "amount": "2 tbsp",
      "notes": "Or gluten-free alternative if needed"
    },
    {
      "name": "1 tablespoon sesame oil",
      "amount": "1 tbsp",
      "notes": ""
    },
    {
      "name": "1/4 cup (60ml) water",
      "amount": "1/4 cup (60ml)",
      "notes": ""
    },
    {
      "name": "Salt and pepper, to taste",
      "amount": null,
      "notes": ""
    }
