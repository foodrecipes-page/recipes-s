{
  "title": "Smoky Brazilian Chicken Pilaf",
  "description": "A pungent and flaky Brazilian dish featuring jasmine rice and chicken, perfect for a flexitarian diet",
  "cuisine": "Brazilian",
  "diet": [
    "flexitarian",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "jasmine rice",
      "amount": "2 cups"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "diced tomatoes",
      "amount": "1 can"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large skillet over medium-high heat",
    "Add the chicken to the skillet and cook until browned, about 5 minutes",
    "Add the onion and garlic to the skillet and cook until the onion is translucent",
    "Add the smoked paprika, salt, and black pepper to the skillet and stir to combine",
    "Add the jasmine rice to the skillet and cook for 1-2 minutes, stirring constantly",
    "Add the diced tomatoes and chicken broth to the skillet and bring to a boil",
    "Reduce the heat to low, cover, and simmer for 20-25 minutes, or until the rice is tender",
    "Fluff the pilaf with a fork and serve hot on a talavera plate"
  ],
