{
  "title": "Sour Silky Portuguese Pumpkin Stew",
  "description": "A satvik-friendly, sour, and silky Portuguese-inspired pumpkin stew made with a soffritto base and quickly prepared for a weeknight meal.",
  "cuisine": "Portuguese",
  "diet": [
    "vegetarian",
    "gluten-free"
