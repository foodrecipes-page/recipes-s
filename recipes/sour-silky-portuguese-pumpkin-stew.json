      "amount": "1/4 tsp",
      "notes": ""
    },
    {
      "name": "salt",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp",
      "notes": ""
    },
    {
      "name": "fresh parsley",
      "amount": "chopped",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Heat olive oil in a large pot over medium heat.",
    "Add the finely chopped onion and saut\u00175 over until softened, about 5 minutes.",
    "Add the minced garlic and cook for another minute.",
    "Add the soffritto base and cook for 1-2 minutes until fragrant.",
    "Add the canned crushed tomatoes, nutmeg, salt, and black pepper. Stir to combine.",
    "Add the cubed pumpkin and stir to coat with the tomato mixture.",
    "Pour in the white wine vinegar and bring the mixture to a simmer.",
    "Reduce heat to low and let the stew cook, covered, for 20-25 minutes or until the pumpkin is tender.",
    "Taste and adjust the seasoning as needed.",
    "Garnish with chopped fresh parsley if desired.",
    "Serve warm and enjoy!"
  ],
