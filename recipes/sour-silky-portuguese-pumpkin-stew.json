      "name": "pumpkin",
      "amount": "1 small pie pumpkin, about 2 lbs",
      "notes": ""
    },
    {
      "name": "soffritto base",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "canned crushed tomatoes",
      "amount": "1 can (14 oz)",
      "notes": ""
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": ""
    },
    {
