      "amount": "2 medium, thinly sliced"
    },
    {
      "name": "Zucchini",
      "amount": "1 medium, sliced"
    },
    {
      "name": "Red Bell Pepper",
      "amount": "1 large, sliced"
    },
    {
      "name": "Vinegar",
      "amount": "2 tablespoons"
    },
