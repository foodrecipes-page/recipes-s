      "amount": "1 medium sliced"
    },
    {
      "name": "Shiitake mushrooms",
      "amount": "1 cup sliced"
    },
    {
      "name": "Spinach",
      "amount": "1 cup chopped"
    },
    {
      "name": "Toasted sesame seeds",
      "amount": "1 tbsp"
    },
    {
      "name": "Scallion",
      "amount": "2 sliced",
      "notes": "for garnish"
    }
  ],
  "instructions": [
    "Heat sesame oil in a heavy pot over medium heat.",
    "Add minced garlic and ginger, sauté until fragrant.",
    "Add sliced carrot and mushrooms, cook until softened.",
    "Pour in vegetable broth and bring to a gentle simmer.",
    "Stir in soy sauce and vanilla extract, letting the flavors meld.",
    "Add tofu cubes to the pot and simmer for 10 minutes.",
    "Toss in spinach and cook until wilted.",
    "Remove from heat, sprinkle toasted sesame seeds, and garnish with sliced scallion.",
    "Serve hot with steamed rice or noodles."
