{
  "title": "Smoky Sour Croatian Asparagus Gratin",
  "description": "A fragrant, tangy gratin featuring fresh asparagus, smoked paprika, and a creamy lemony sauce, finished with flaky breadcrumbs and dill.",
  "cuisine": "Croatian",
  "diet": [
    "halal"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "fresh asparagus",
      "amount": "800 g",
      "notes": "trim ends, cut into 2.5 cm pieces"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp",
      "notes": "halal-certified"
    },
    {
      "name": "smoked salt",
      "amount": "1 tsp",
      "notes": "halal-certified"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "extra-virgin"
    },
    {
      "name": "garlic cloves",
      "amount": "2",
      "notes": "minced"
    },
    {
      "name": "small onion",
      "amount": "1",
      "notes": "finely chopped"
    },
    {
      "name": "heavy cream",
      "amount": "200 ml",
      "notes": "full-fat"
    },
    {
      "name": "Greek yogurt",
      "amount": "100 g",
      "notes": "plain"
    },
    {
      "name": "fresh lemon juice",
      "amount": "2 tbsp",
      "notes": "juiced"
    },
    {
      "name": "parmesan cheese",
      "amount": "50 g",
      "notes": "grated"
    },
    {
      "name": "breadcrumbs",
      "amount": "2 tbsp",
      "notes": "preferably homemade"
    },
    {
      "name": "fresh dill",
      "amount": "1 tbsp",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat oven to 200°C (400°F).",
    "In a large skillet, heat olive oil over medium heat. Add onion and garlic, sauté until translucent (~3 min).",
    "Add smoked paprika and smoked salt, stir for 30 seconds.",
    "Fold in asparagus, cooking until just tender, about 5 minutes, stirring frequently.",
    "Transfer asparagus mixture to a baking dish. In a bowl, whisk together heavy cream, Greek yogurt, lemon juice, and parmesan until smooth.",
    "Pour the sauce over the asparagus, ensuring even coverage.",
    "Top with breadcrumbs and remaining dill.",
    "Bake for 20 minutes, or until the top is golden and the sauce bubbles.",
    "Remove from oven, let rest 5 minutes before serving."
  ],
