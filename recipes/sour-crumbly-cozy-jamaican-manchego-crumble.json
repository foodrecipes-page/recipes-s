{
  "title": "Sour Crumbly Cozy Jamaican Manchego Crumble",
  "description": "This savory dish features manchego cheese in a sour and crumbly topping that's perfect for breakfast or brunch, with Mediterranean flavors.",
  "cuisine": "Jamaican",
  "diet": null,
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "Manchego Cheese",
      "amount": "1 cup grated"
    },
    {
      "name": "Almond Milk",
      "amount": "3/4 cup"
    },
    {
      "name": "Butter",
      "amount": "1/4 cup, melted"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "All-Purpose Flour",
      "amount": "1/2 cup"
    },
    {
      "name": "Coconut Sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "Vanilla Extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "Ground Cumin",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "A pinch"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C). Grease a baking dish.",
    "In a bowl, mix almond milk with melted butter and olive oil until well combined.",
    "Add ground cumin, coconut sugar, vanilla extract, and salt. Stir until dissolved.",
    "Stir in grated manchego cheese until fully incorporated into the mixture.",
    "Transfer the mixture evenly to the prepared baking dish.",
    "Combine flour with a pinch of salt and sprinkle over the cheese mixture.",
    "Bake for 25-30 minutes or until golden brown on top. Serve warm."
  ],
