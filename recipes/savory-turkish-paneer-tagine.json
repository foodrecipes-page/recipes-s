      "amount": "1 block",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "tomatoes",
      "amount": "2 cups",
      "notes": "diced"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "Heat the olive oil in the ceramic tagine over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the diced tomatoes, paprika, cumin, salt, and black pepper, and stir to combine.",
    "Add the cubed paneer and chicken broth, and stir to combine.",
    "Bring the mixture to a simmer.",
    "Cover the tagine and transfer it to the preheated oven.",
    " Bake for 25 minutes.",
    "Remove the tagine from the oven and flambe the dish with a little bit of oil.",
    "Serve the tagine hot over rice or with some crusty bread."
  ],
