{
  "title": "Spicy Pak Choi Spring Rolls",
  "description": "These crunchy spring rolls feature a spicy pak choi filling with a touch of ginger and sesame oil for an aromatic and satisfying snack.",
  "cuisine": "german",
  "diet": null,
