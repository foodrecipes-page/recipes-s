  "ingredients": [
    {
      "name": "pak choi",
      "amount": "1 cup fresh, finely shredded"
    },
    {
      "name": "ginger",
      "amount": "a small piece, minced"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "red pepper flakes",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "sesame seeds",
      "amount": "1 tablespoon, lightly toasted"
    },
    {
      "name": "salt",
      "amount": "a pinch"
    },
    {
      "name": "rice paper wrappers",
      "amount": "8-10 sheets"
    },
    {
      "name": "lemon wedges",
      "amount": "for serving"
    }
  ],
  "instructions": [
    "Place the shredded pak choi in a large bowl. Add minced ginger, sesame oil, red pepper flakes, salt, and mix well.",
    "Pour half of the mixture into each rice paper wrapper, leaving about an inch at one end for rolling.",
    "Dip a finger in water and smooth any edges to seal the roll. Place on a plate with remaining filling.",
    "Serve with lemon wedges on the side."
  ],
