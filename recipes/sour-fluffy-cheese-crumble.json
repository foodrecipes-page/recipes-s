{
  "title": "Sour Fluffy Cheese Crumble",
  "description": "A light and fluffy low-carb American dish featuring cheese slices that are slowly cooked until they become tender and slightly tangy.",
  "cuisine": "American",
  "diet": [
    "low-carb"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "1 cup shredded mozzarella cheese",
      "amount": "cup"
    },
    {
      "name": "2 tablespoons fresh lemon juice",
      "amount": "tbsp"
    },
    {
      "name": "Pinch of salt",
      "amount": "pinch"
    },
    {
      "name": "1/4 teaspoon black pepper",
      "amount": "teaspoon"
    },
    {
      "name": "1/4 cup grated Parmesan cheese",
      "amount": "cup"
    },
    {
      "name": "3 tablespoons unsalted butter",
      "amount": "tbsp"
    },
    {
      "name": "1 tablespoon all-purpose flour",
      "amount": "tbsp"
    }
  ],
  "instructions": [
    "Preheat your oven to 200°F (93°C).",
    "Mix together the shredded mozzarella cheese, lemon juice, salt, and black pepper in a mixing bowl.",
    "Fold in the Parmesan cheese and butter. Mix well until combined evenly.",
    "Stir in the flour until no lumps remain.",
    "Pour the mixture into an oven-safe dish that is lightly greased or lined with parchment paper.",
    "Bake for about 45 minutes, or until the cheese slices are puffed up and golden-brown on top. Serve warm as a dessert."
  ],
