  "ingredients": [
    {
      "name": "2 tablespoons olive oil",
      "amount": "tbsp"
    },
    {
      "name": "1 cup Medjool dates, halved",
      "amount": "cup",
      "notes": "soaked and drained"
    },
    {
      "name": "1 small red bell pepper, diced",
      "amount": "cup"
    },
    {
      "name": "1/2 cup finely chopped scallions (green onions)",
      "amount": "cup"
    },
    {
      "name": "1 teaspoon ground cumin",
      "amount": "tsp"
    },
    {
      "name": "1/4 teaspoon smoked paprika",
      "amount": "tsp"
    },
    {
      "name": "Pinch of red pepper flakes",
      "amount": "pinch"
    },
    {
      "name": "Juice of 1 lime",
      "amount": ""
    },
    {
      "name": "Salt to taste",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large skillet over medium-high heat.",
    "Add dates, red bell pepper, and scallions. Stir-fry for about 2-3 minutes until vegetables start to soften.",
    "Stir in cumin and smoked paprika. Cook for an additional minute.",
    "Fold in lime juice and season with salt. Stir well to combine all ingredients evenly.",
    "Remove from heat immediately to prevent overcooking the dates which can cause them to become mushy."
  ],
