      "name": "lamb shoulder",
      "amount": "2 pounds",
      "notes": "boneless"
    },
    {
      "name": "malt vinegar",
      "amount": "1/4 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "low-sodium"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup",
      "notes": "low-sodium"
    }
  ],
  "instructions": [
    "Heat the olive oil in the stone-bowl-dolsot over medium heat",
    "Add the chopped onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional minute",
    "Add the lamb shoulder and cook until browned on all sides, about 5 minutes",
    "Add the malt vinegar, dried oregano, paprika, salt, and black pepper, stirring to combine",
    "Pour in the chicken broth and bring to a boil",
    "Reduce the heat to low and simmer, covered, for 2 1/2 hours",
    "Remove the lid and continue to simmer for an additional 30 minutes",
    "Serve the lamb and sauce hot, garnished with fresh parsley or oregano"
  ],
