      "notes": "boneless, skinless"
    },
    {
      "name": "green chillies",
      "amount": "3-4",
      "notes": "medium to hot"
    },
    {
      "name": "ginger",
      "amount": "1 tbsp fresh or 2 tsp dried",
      "notes": "for extra flavor and health benefits"
    },
    {
      "name": "soya sauce",
      "amount": "2 tbsp",
      "notes": "low sodium if available"
    },
    {
      "name": "tomato paste",
      "amount": "1 tbsp"
    },
    {
      "name": "red curry paste",
      "amount": "1 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "oil",
      "amount": "2 tbsp",
      "notes": "vegetable or canola oil"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "sliced thinly for easier cooking"
    },
    {
      "name": "capsicum (bell peppers)",
      "amount": "2-3 medium-sized, sliced thickly"
    },
    {
      "name": "salt and pepper",
      "amount": "to taste",
      "notes": "adjust to personal preference"
    }
  ],
  "instructions": [
    "Heat oil in a large wok or frying pan over medium-high heat.",
    "Add onions and bell peppers, stir-fry for about 5 minutes until slightly softened.",
    "Add chicken fillets and green chillies; season with salt and pepper. Stir fry until the meat is browned on all sides.",
    "Stir in ginger paste (if using fresh), curry paste, and tomato paste. Mix well to combine.",
    "Pour in soya sauce and stir continuously for about 2 minutes until sauce thickens slightly.",
    "Add sliced capsicum pieces back into pan. Continue stirring till the chicken is fully cooked through.",
    "Serve hot with steamed rice or quinoa."
  ],
