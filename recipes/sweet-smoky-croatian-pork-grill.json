{
  "title": "Sweet Smoky Croatian Pork Grill",
  "description": "A light and tangy Croatian-inspired pork dish featuring a sweet and smoky glaze made with red chilli powder, perfect for a weeknight dinner.",
  "cuisine": "Croatian",
  "diet": null,
