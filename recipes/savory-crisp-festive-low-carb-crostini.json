      "name": "Low Carb Bread Slices",
      "amount": "2 cups"
    },
    {
      "name": "Saskatoon Berries",
      "amount": "1 cup frozen"
    },
    {
      "name": "Extra Virgin Olive Oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "Minced Garlic",
      "amount": "1 clove"
    },
