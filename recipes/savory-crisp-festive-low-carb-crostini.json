{
  "title": "Savory Crisp Festive Low Carb Crostini",
  "description": "A festive low-carb Croatian dish featuring Saskatoon berries in a savory and crisp topping for crostini.",
  "cuisine": "Croatian",
  "diet": [
    "low-carb",
    "vegetarian"
