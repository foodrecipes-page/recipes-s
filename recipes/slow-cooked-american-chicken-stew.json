{
  "title": "Slow Cooked American Chicken Stew",
  "description": "A hearty and citrusy stew featuring fresh thyme, perfect for a lazy Sunday, made in a traditional kazan cauldron and shaped like nigiri for a fun twist, this dish is paleo friendly.",
  "cuisine": "American",
  "diet": [
    "paleo"
  ],
