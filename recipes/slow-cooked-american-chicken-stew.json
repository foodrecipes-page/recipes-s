  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "fresh thyme",
      "amount": "2 tablespoons",
      "notes": "chopped"
    },
    {
      "name": "lemon juice",
      "amount": "1/4 cup"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "chopped"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in the kazan cauldron over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the chopped carrots and celery and cook for 5 minutes.",
    "Add the chicken to the cauldron and cook until it is browned on all sides.",
    "Add the chicken broth, lemon juice, salt, and black pepper to the cauldron and stir to combine.",
    "Reduce the heat to low and simmer the stew for 6 hours.",
    "Stir in the chopped fresh thyme.",
    "Use two spoons to shape the stew into nigiri shapes.",
    "Serve the stew hot."
  ],
