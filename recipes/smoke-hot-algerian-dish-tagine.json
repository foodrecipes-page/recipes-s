  "instructions": [
    "Heat oil in a 5-quart Dutch oven over medium-high heat.",
    "Brown lamb in batches until browned, about 5 minutes. Remove from pot.",
    "Reduce heat to medium and cook onion until softened, about 5 minutes.",
    "Add garlic, ginger, cumin, coriander, cayenne pepper, and smoked paprika. Cook, stirring constantly, for 1 minute.",
    "Add preserved lemon, chicken broth, and tomatoes. Stir to combine.",
    "Return lamb to pot, cover, and bring to a boil.",
    "Reduce heat to low and simmer, covered, until lamb is tender, about 1 hour.",
    "Season with salt and pepper to taste.",
    "Serve hot over couscous"
  ],
