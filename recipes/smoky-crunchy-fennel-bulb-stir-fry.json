      "name": "1 medium fennel bulb",
      "amount": "",
      "notes": "Rinse thoroughly"
    },
    {
      "name": "2 tablespoons vegetable oil",
      "amount": "",
      "notes": ""
    },
    {
      "name": "Pinch of salt and pepper",
      "amount": "",
      "notes": "To taste"
    },
    {
      "name": "1 cup chopped green onions",
      "amount": "",
      "notes": "Chiffonade for garnish"
    },
    {
      "name": "2 tablespoons soy sauce",
      "amount": "",
      "notes": ""
    },
    {
      "name": "Juice of 1 lime",
      "amount": "",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat a non-stick skillet over medium heat.",
    "Halve the fennel bulb lengthwise and remove the core. Slice into thin rounds about 1/4 inch thick.",
    "Sprinkle both sides of the sliced fennel with salt, pepper, and oil.",
    "Place the fennel in the skillet and cook until lightly browned on both sides, about 5-7 minutes per side, flipping once.",
    "Squeeze lime juice over cooked fennel to add a tangy touch.",
    "Toss with chopped green onions for extra freshness."
  ],
