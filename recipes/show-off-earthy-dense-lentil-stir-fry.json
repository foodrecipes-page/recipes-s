  "ingredients": [
    {
      "name": "1 cup green lentils",
      "amount": "cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "2 tablespoons olive oil",
      "amount": "tbsp"
    },
    {
      "name": "1 small onion, finely chopped",
      "amount": "medium"
    },
    {
      "name": "3 cloves garlic, minced",
      "amount": "cloves"
    },
    {
      "name": "2 cups water or vegetable broth",
      "amount": "cup"
    },
    {
      "name": "2 tablespoons sazon seasoning (or equivalent), optional",
      "amount": "tbsp"
    },
    {
      "name": "Salt and pepper to taste",
      "amount": ""
    },
    {
      "name": "Fresh parsley, chopped for garnish",
      "amount": ""
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet or wok over medium heat.",
    "Add onion and garlic; sauté until softened, about 5 minutes.",
    "Stir in the lentils and add water or broth. Bring to a simmer.",
    "If using sazon seasoning, stir it into the lentils now.",
    "Reduce heat to low, cover, and let cook for 10-15 minutes until the lentils are tender but still have some bite.",
    "Season with salt and pepper as needed.",
    "Garnish with fresh parsley before serving."
