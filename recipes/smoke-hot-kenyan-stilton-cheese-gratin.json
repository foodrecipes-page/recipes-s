{
  "title": "Smoked-Hot Kenyan Stilton Cheese Gratin",
  "description": "A garlicky, gooey, and romantic Kenyan dish featuring Stilton cheese, with a smoky twist.",
  "cuisine": "kenyan",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "stilton cheese",
      "amount": "8 ounces"
    },
    {
      "name": "smoked paprika",
      "amount": "2 teaspoons"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "sodium-free seasoning",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "heavy cream",
      "amount": "1/2 cup"
    },
    {
      "name": "chopped fresh parsley",
      "amount": "2 tablespoons"
    },
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Butter a 9x13-inch baking dish.",
    "Arrange half of the Stilton cheese slices in the baking dish.",
    "Sprinkle the smoked paprika, garlic powder, and sodium-free seasoning over the cheese.",
    "Pour in the heavy cream, then sprinkle with black pepper to taste.",
    "Top with the remaining Stilton cheese slices.",
    "Dot the top with the unsalted butter and sprinkle with chopped parsley.",
    "Bake for 20 minutes, or until the cheese is melted and bubbly.",
    "Remove from the oven and let cool for a few minutes.",
    "Serve hot, garnished with additional parsley if desired."
  ],
