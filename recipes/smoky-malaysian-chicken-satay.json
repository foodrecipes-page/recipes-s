      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "cut into satay strips"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup"
    },
    {
      "name": "red wine",
      "amount": "1/4 cup"
    },
    {
      "name": "soy sauce",
      "amount": "2 tablespoons"
    },
    {
