{
  "title": "Savory Spicy Uruguayan Beef Skewers",
  "description": "A briny and juicy Uruguayan dish featuring Sichuan pepper and nuka-pickle, perfect for adventurous eaters looking for a high-protein meal.",
  "cuisine": "Uruguayan",
  "diet": [
    "high-protein",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "beef sirloin",
      "amount": "1 pound",
      "notes": "cut into 1-inch cubes"
    },
    {
      "name": "Sichuan pepper",
      "amount": "2 tablespoons",
      "notes": "toasted and ground"
    },
    {
      "name": "nuka-pickle",
      "amount": "1/4 cup",
      "notes": "finely chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat grill to medium-high heat.",
    "In a large bowl, whisk together Sichuan pepper, nuka-pickle, garlic, salt, and black pepper.",
    "Add the beef cubes to the bowl and toss to coat evenly with the spice mixture.",
    "Thread the beef cubes onto skewers, leaving a small space between each piece.",
    "Brush the skewers with olive oil and grill for 8-10 minutes, turning occasionally.",
    "Transfer the skewers to a plate and garnish with chopped parsley.",
    "Serve immediately and enjoy.",
    "Note: this recipe is for refrigerator pickling/preserving only — store in the refrigerator and consume within 1 week. Do not water-bath can without an acid (vinegar or lemon juice)."
  ],
