{
  "title": "Smoky Norwegian Egg Pancake",
  "description": "A pillowy, smoky egg pancake with subtle smoked salmon flavor, perfect for kids and anti‑inflammatory friendly.",
  "cuisine": "Norwegian",
  "diet": null,
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "6 large free-range eggs",
      "amount": "6",
      "notes": "beat until frothy"
    },
    {
      "name": "120 ml oat milk",
      "amount": "120 ml",
      "notes": "low-fat, unsweetened"
    },
    {
      "name": "120 g chickpea flour",
      "amount": "120 g",
      "notes": "gluten-free, high protein"
    },
    {
      "name": "30 g smoked salmon, finely chopped",
      "amount": "30 g",
      "notes": "adds smoky flavor"
    },
    {
      "name": "1 tsp ground dill",
      "amount": "1 tsp",
      "notes": "for Norwegian aroma"
    },
    {
      "name": "1 tbsp olive oil",
      "amount": "1 tbsp",
      "notes": "for cooking"
    },
    {
      "name": "1 tsp sea salt",
      "amount": "1 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "1/4 tsp black pepper",
      "amount": "1/4 tsp",
      "notes": "freshly ground"
    }
  ],
  "instructions": [
    "Whisk the eggs until frothy in a large bowl.",
    "Slowly stir in oat milk and chickpea flour until the batter is smooth.",
    "Fold in smoked salmon and ground dill gently.",
    "Heat olive oil in a non-stick skillet over medium heat.",
    "Pour about 1/4 cup of batter into the skillet and spread it into a thin circle.",
    "Cook for 2 minutes until the edges lift, then flip carefully.",
    "Seal the edges with a spatula and cook for another 1.5 minutes.",
    "Transfer the pancake to a plate and serve warm or chilled with a drizzle of yogurt if desired."
  ],
