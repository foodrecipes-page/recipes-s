      "amount": "2 tsp"
    },
    {
      "name": "coconut milk",
      "amount": "1 can (14 oz)"
    },
    {
      "name": "lime juice",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "fresh cilantro",
      "amount": "chopped, for garnish"
    }
  ],
  "instructions": [
    "Heat oil in a large pan over medium heat.",
    "Add onion, garlic, and ginger, and cook until the onion is translucent.",
    "Add the scotch bonnet pepper and cook for 1 minute.",
    "Add the curry powder and cook for 1 minute, stirring constantly.",
    "Add the diced nectarines, coconut milk, and lime juice. Stir to combine.",
    "Bring the mixture to a simmer and cook for 10-12 minutes, or until the nectarines are tender.",
    "Season with salt to taste.",
    "Garnish with chopped cilantro and serve over rice or with roti.",
    "Refrigerate or freeze any leftovers.",
    "Reheat gently before serving."
  ],
