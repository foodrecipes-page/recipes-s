      "name": "Canned tuna in water (drained)",
      "amount": "1 can (120g)"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "Olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "Chopped red onion",
      "amount": "1/2 cup"
    },
    {
      "name": "Chopped fresh parsley",
      "amount": "1/4 cup"
    },
    {
      "name": "Chopped fresh dill",
      "amount": "1/4 cup"
    },
    {
      "name": "Minced garlic",
      "amount": "1 clove"
    },
    {
      "name": "Crushed bay leaves",
      "amount": "2-3 leaves"
    },
    {
      "name": "Spicy tadka oil (see note)*",
      "amount": "1 tsp"
    },
    {
