      "amount": "100g"
    },
    {
      "name": "onions",
      "amount": "2 medium, finely chopped"
    },
    {
      "name": "carrots",
      "amount": "3 large, diced"
    },
    {
      "name": "peas",
      "amount": "150g canned or frozen"
    },
    {
      "name": "flour",
      "amount": "1 tbsp"
    },
    {
      "name": "sugar",
      "amount": "2 tsp"
    },
    {
      "name": "salt",
      "amount": "a pinch"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat oil in a pan over medium heat.",
    "Add suet and onions, cook until translucent.",
    "Stir in flour, mix well to avoid lumps, then gradually add sugar and salt while stirring continuously for about 2 minutes.",
    "Gradually pour in liquid (water or stock) ensuring there are no lumps, let it simmer for a minute.",
    "Add carrots and peas, cover with a lid, reduce heat to low, cook until all ingredients are soft and well combined.",
    "Serve hot."
  ],
