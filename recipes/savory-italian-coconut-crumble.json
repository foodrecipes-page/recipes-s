{
  "title": "Savory Italian Coconut Crumble",
  "description": "A crisp and savory dish featuring coconut flakes with an Italian twist, perfect for showing off in a vegan-friendly meal.",
  "cuisine": [
    "Italian",
    "Plant-Based"
  ],
  "diet": [
    "vegan"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Coconut Flakes",
      "amount": "2 cups"
    },
    {
      "name": "Olive Oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Sun-Dried Tomatoes, Finely Chopped",
      "amount": "1/3 cup"
    },
    {
      "name": "Fresh Basil Leaves",
      "amount": "1 tablespoon fresh or 1 teaspoon dried"
    },
    {
      "name": "Red Pepper Flakes (optional)",
      "amount": "A pinch"
    },
    {
      "name": "Coconut Milk",
      "amount": "2 tablespoons"
    },
    {
      "name": "Almond Meal or All-Purpose Flour",
      "amount": "3/4 cup"
    }
  ],
  "instructions": [
    "Heat olive oil in a non-stick pan over medium heat.",
    "Add coconut flakes and sun-dried tomatoes, stirring occasionally for about 5 minutes until fragrant and lightly golden.",
    "Stir in basil leaves and red pepper flakes (if using).",
    "Gradually stir in coconut milk to prevent clumping. Let it cook down slightly and thicken further.",
    "Remove from heat and mix with almond meal or flour, stirring well until a smooth crumble forms.",
    "Allow to cool before serving as a side dish or topping over grain bowls."
  ],
