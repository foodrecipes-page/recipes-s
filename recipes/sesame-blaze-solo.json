      "name": "sesame seed oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "red pepper flakes",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "garlic cloves",
      "amount": "3 cloves, minced"
    },
    {
      "name": "lamb or chicken mince",
      "amount": "1 cup"
    },
    {
      "name": "cumin seeds",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "coriander seeds",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "ground cayenne pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "fresh parsley",
      "amount": "1 handful, chopped"
    },
    {
      "name": "basil leaves",
      "amount": "2-3, finely chopped"
    }
  ],
  "instructions": [
    "Heat sesame seed oil in a pan over medium heat.",
    "Add minced garlic and sauté for about 1 minute until fragrant.",
    "Stir in red pepper flakes and ground cayenne pepper. Cook for an additional 30 seconds.",
    "Gradually add mince, stirring constantly to break it up into crumbles. Cook until browned on all sides, about 5-7 minutes.",
    "Sprinkle cumin seeds and coriander seeds over the mixture, stir well, then cook for another minute.",
    "Remove from heat and mix in lime juice. Stir in chopped parsley and basil leaves.",
    "Serve hot as a solo dinner dish with crusty bread."
  ],
