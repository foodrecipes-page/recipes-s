{
  "title": "Spicy Velvety Slovakian Pepper Stir-fry",
  "description": "This whole30-friendly spicy velvety dish features sweet peppadew peppers in a savory sauce for a weeknight meal.",
  "cuisine": "Slovakian",
  "diet": [
    "whole30"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Peppadew Peppers",
      "amount": "1 can (6 oz)"
    },
    {
      "name": "Ground Beef",
      "amount": "250g"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves"
    },
    {
      "name": "Red Onion",
      "amount": "1/4 cup, finely chopped"
    },
    {
      "name": "Tomato Paste",
      "amount": "1 tbsp"
    },
    {
      "name": "Red Peppers",
      "amount": "2 cups, diced"
    },
    {
      "name": "Vinegar",
      "amount": "1 tbsp"
    },
    {
      "name": "Olive Oil",
      "amount": "3 tbsp"
    },
    {
      "name": "Salt",
      "amount": "To taste"
    },
    {
      "name": "Black Pepper",
      "amount": "To taste"
    },
    {
      "name": "Sour Cream or Coconut Milk",
      "amount": "4 tbsp"
    }
  ],
  "instructions": [
    "Preheat oil in a large skillet over medium-high heat.",
    "Add ground beef and cook until browned, breaking it into small pieces as it cooks.",
    "Stir in garlic and onion, cooking until softened.",
    "Add red peppers, peppadew peppers, tomato paste, vinegar, salt, black pepper, and 2 tbsp of olive oil. Stir well to combine all ingredients.",
    "Reduce heat to medium-low and simmer for about 10 minutes or until slightly thickened.",
    "Stir in sour cream or coconut milk and cook for another minute until combined and heated through.",
    "Serve hot with whole grain bread on the side."
  ],
