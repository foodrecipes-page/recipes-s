{
  "title": "Savory Spiced Tunisian Red Cabbage Bowl",
  "description": "A crunchy, cozy bowl of red cabbage tossed with aromatic Tunisian spices for a low-carb, keto-friendly meal.",
  "cuisine": "Tunisian",
  "diet": [
    "keto-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "red cabbage",
      "amount": "1 head (approx 500g)",
      "notes": "finely sliced"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "harissa paste",
      "amount": "1 tbsp"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "lemon",
      "amount": "1 (juiced)",
      "notes": "for freshness"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "sliced almonds",
      "amount": "3 tbsp"
    },
    {
      "name": "fresh parsley",
      "amount": "2 tbsp chopped",
      "notes": "optional garnish"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium heat.",
    "Add harissa paste, cumin, coriander, and smoked paprika, sauté for 1 minute until fragrant.",
    "Add sliced red cabbage, stir to coat, cook for 5 minutes until slightly softened.",
    "Pour in lemon juice, season with salt and pepper, and continue cooking for another 3 minutes until cabbage is tender but still crisp.",
    "Remove from heat, stir in sliced almonds, and drizzle with extra olive oil if desired.",
    "Transfer to bowls, garnish with chopped parsley, and serve immediately."
  ],
