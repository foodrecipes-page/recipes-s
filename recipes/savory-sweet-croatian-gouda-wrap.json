  "ingredients": [
    {
      "name": "Croatian Gouda cheese",
      "amount": "8 oz",
      "notes": "sliced"
    },
    {
      "name": "corn husk wraps",
      "amount": "4 large"
    },
    {
      "name": "sweet glaze",
      "amount": "1/4 cup"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "fresh dill",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "pepper",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a small bowl, mix together the sweet glaze, chopped parsley, and chopped dill.",
    "Brush the corn husk wraps with olive oil on both sides.",
    "Place the sliced gouda cheese on one half of each corn husk wrap.",
    "Drizzle the sweet glaze mixture over the gouda cheese.",
    "Sprinkle salt and pepper to taste.",
    "Fold the other half of the corn husk wrap over the filling to enclose.",
    "Place the wraps on a baking sheet lined with parchment paper.",
    "Bake for 10 minutes or until the cheese is melted and the wraps are crispy."
  ],
