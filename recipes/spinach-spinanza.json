    },
    {
      "name": "1 medium onion",
      "amount": "",
      "notes": "Chopped finely"
    },
    {
      "name": "3 cloves garlic",
      "amount": "",
      "notes": "Minced finely"
    },
    {
      "name": "2 cups cherry tomatoes, halved",
      "amount": "",
      "notes": ""
    },
    {
