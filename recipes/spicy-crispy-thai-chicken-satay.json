      "amount": "1/4 cup (30g) chopped fresh",
      "notes": "adjust to desired flavor"
    },
    {
      "name": "Salt",
      "amount": "to taste",
      "notes": "adjust to desired flavor"
    },
    {
      "name": "Vegetable oil",
      "amount": "for air-frying",
      "notes": "adjust to desired crispiness"
    }
