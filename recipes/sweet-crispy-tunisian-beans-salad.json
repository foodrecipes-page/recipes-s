{
  "title": "Sweet Crispy Tunisian Beans Salad",
  "description": "A refreshing, sweet and crunchy bean salad with a spicy chilibean sauce thats a perfect hangover cure.",
  "cuisine": "Tunisian",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
