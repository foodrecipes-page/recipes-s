  "ingredients": [
    {
      "name": "cannellini beans (canned, drained and rinsed)",
      "amount": "1 can (400g)"
    },
    {
      "name": "cherry tomatoes",
      "amount": "1 cup, halved"
    },
    {
      "name": "cucumber",
      "amount": "1/2 cup, diced"
    },
    {
      "name": "red onion",
      "amount": "1/4 cup, thinly sliced"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup, chopped"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "honey",
      "amount": "1 tsp"
    },
    {
      "name": "harissa paste",
      "amount": "1 tsp"
    },
    {
      "name": "tahini",
      "amount": "1 tbsp"
    },
    {
      "name": "pepitas (pumpkin seeds)",
      "amount": "1 tbsp",
      "notes": "lightly toasted"
    }
  ],
  "instructions": [
    "In a large bowl, combine the drained cannellini beans, halved cherry tomatoes, diced cucumber, sliced red onion, and chopped parsley.",
    "Whisk together lemon juice, olive oil, honey, harissa paste, and tahini until smooth to make the dressing.",
    "Pour the dressing over the bean mixture and toss gently to coat everything evenly.",
    "Taste and adjust seasoning if needed with extra salt, pepper, or honey.",
    "Transfer the salad to a serving dish and sprinkle the toasted pepitas on top.",
    "Refrigerate for at least 15 minutes to allow flavors to meld.",
    "Serve chilled or at room temperature as a light lunch or snack."
  ],
