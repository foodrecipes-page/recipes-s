      "name": "basmati rice",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and diced"
    },
    {
      "name": "zucchini",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "onion",
      "amount": "1 small",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "chilled butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the water in a large saucepan over high heat until it boils",
    "Add the basmati rice to the boiling water, stir gently, then reduce the heat to low and cover the saucepan",
    "Simmer the rice for 15 minutes or until it is al-dente",
    "While the rice is cooking, heat the chilled butter in a large skillet over medium heat",
    "Add the diced onion to the skillet and cook until it is translucent",
    "Add the minced garlic to the skillet and cook for 1 minute",
    "Add the diced carrots and zucchini to the skillet and cook until they are tender",
    "Fluff the cooked rice with a fork and stir in the cooked vegetables, salt, black pepper, and paprika",
    "Serve the pilaf hot"
  ],
