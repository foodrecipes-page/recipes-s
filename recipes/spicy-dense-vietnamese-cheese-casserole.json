      "name": "beurre monte",
      "amount": "4 tablespoons",
      "notes": "see notes"
    },
    {
      "name": "shredded mexican cheese",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "all-purpose flour",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "unsweetened almond milk",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "chopped shallots",
      "amount": "1/2 cup",
      "notes": "caramelize for 10 minutes before using"
    },
    {
