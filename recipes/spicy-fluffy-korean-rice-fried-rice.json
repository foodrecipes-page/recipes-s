    {
      "name": "cooked Korean rice",
      "amount": "2 cups",
      "notes": "preferably day-old rice"
    },
    {
      "name": "hot chilli powder",
      "amount": "1 tsp"
    },
    {
      "name": "bhuna masala",
      "amount": "1 tsp"
    },
    {
      "name": "vegan soy sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "sesame oil",
      "amount": "1 tbsp"
    },
    {
      "name": "small onion",
      "amount": "1",
      "notes": "diced"
    },
    {
      "name": "cloves of garlic",
      "amount": "2",
      "notes": "minced"
    },
    {
      "name": "frozen peas and carrots",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat sesame oil in a large skillet or wok over medium-high heat.",
    "Add diced onion and cook until translucent, about 3-4 minutes.",
    "Add minced garlic and cook for another minute, until fragrant.",
    "Add hot chilli powder and bhuna masala, and stir for 1 minute.",
    "Add frozen peas and carrots, and cook until thawed.",
    "Add cooked Korean rice to the skillet or wok, and stir-fry for about 5 minutes, breaking up any clumps with a spatula.",
    "Add vegan soy sauce, and stir-fry for another minute.",
    "Season with salt to taste.",
    "Transfer the fried rice to a serving platter, and garnish with chopped scallions."
  ],
