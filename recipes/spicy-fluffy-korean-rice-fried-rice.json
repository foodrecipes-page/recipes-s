{
  "title": "Spicy Fluffy Korean Rice Fried Rice",
  "description": "A fresh, fluffy, and spicy Korean dish perfect for midnight cravings, made with hot chilli powder and bhuna, and is vegan-friendly.",
  "cuisine": "Korean",
  "diet": [
    "vegan",
    "gluten-free"
