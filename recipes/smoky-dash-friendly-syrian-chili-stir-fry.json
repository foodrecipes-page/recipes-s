{
  "title": "Smoky Dash-Friendly Syrian Chili Stir-fry",
  "description": "A dense and smoky Syrian chili dish that is both savory and flavorful, designed to be enjoyed in a dash-friendly manner suitable for all meals.",
  "cuisine": "Syrian",
  "diet": null,
