{
  "title": "Silky Sweet French Tomatoes Casserole",
  "description": "A fragrant, vegan-friendly casserole of vine tomatoes, coconut milk, and herbs, slow‑cooked to silky perfection for a comforting weeknight dinner.",
  "cuisine": "french",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "vine tomatoes (canned whole)",
      "amount": "4 cups (896g)"
    },
    {
      "name": "coconut milk, full‑fat",
      "amount": "1 cup (240ml)"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp (30ml)"
    },
    {
      "name": "red onion, diced",
      "amount": "1 medium (150g)"
    },
    {
      "name": "garlic cloves, minced",
      "amount": "3 (12g)"
    },
    {
      "name": "granulated sugar",
      "amount": "1 tsp (5g)"
    },
    {
      "name": "dried thyme",
      "amount": "1 tsp (2g)"
    },
    {
      "name": "dried rosemary",
      "amount": "1 tsp (2g)"
    },
    {
      "name": "salt",
      "amount": "1 tsp (6g)"
    },
    {
      "name": "black pepper",
      "amount": "0.5 tsp (1g)"
    },
    {
      "name": "breadcrumb, vegan",
      "amount": "1 cup (120g)"
    },
    {
      "name": "nutritional yeast",
      "amount": "2 tbsp (15g)"
    }
  ],
  "instructions": [
    "Preheat the oven to 325°F (165°C).",
    "Heat the olive oil in a 9x9‑inch baking dish over medium heat.",
    "Add the diced onion and cook until translucent, about 5 minutes.",
    "Stir in the minced garlic and cook for 1 minute.",
    "Add the canned tomatoes, sugar, thyme, rosemary, salt, and pepper; stir to combine.",
    "Simmer on low heat for 5 minutes to meld the flavors.",
    "Pour in the coconut milk and bring the mixture to a gentle simmer.",
    "Cover the dish with foil and bake for 30 minutes.",
    "Remove the foil, stir, then top with breadcrumbs and nutritional yeast; return to oven uncovered for 10 minutes until golden.",
    "Garnish with fresh basil leaves before serving."
  ],
