    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "onion powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "vegan breadcrumbs",
      "amount": "100g"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the raclette-grill to 180 degrees Celsius.",
    "Cut the scamorza cheese into 1-inch cubes.",
    "In a bowl, mix together lemon juice, olive oil, garlic powder, onion powder, salt, and black pepper.",
    "Add the scamorza cheese cubes to the bowl and marinate for 10 minutes.",
    "Roll the marinated scamorza cheese cubes in vegan breadcrumbs to coat.",
    "Thread the coated scamorza cheese cubes onto skewers.",
    "Place the skewers in the raclette-grill and cook for 5 minutes on each side.",
    "Garnish with chopped fresh parsley and serve hot."
  ],
