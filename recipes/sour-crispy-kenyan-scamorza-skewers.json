{
  "title": "Sour Crispy Kenyan Scamorza Skewers",
  "description": "A sour and crispy post-workout Kenyan dish featuring scamorza, served en-croute and vegan-friendly, grilled to perfection in a raclette-grill.",
  "cuisine": "Kenyan",
  "diet": [
    "vegan"
  ],
