{
  "title": "Smoky Roasted Syrian Spinach Curry",
  "description": "A bitter yet gooey Syrian-inspired curry that combines smoky roasted mustard seeds with fresh spinach for a lowcarb, showoff dish.",
  "cuisine": "Syrian",
  "diet": [
    "low-carb"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "fresh spinach",
      "amount": "1 lb (about 450 g)",
      "notes": "washed and roughly chopped"
    },
    {
      "name": "onion",
      "amount": "1 large, diced"
    },
    {
      "name": "garlic",
      "amount": "2 cloves, minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch, minced"
    },
    {
      "name": "mustard seeds",
      "amount": "1 tbsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "ground sumac",
      "amount": "1/2 tsp"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "vegetable broth",
      "amount": "1 cup (240 ml)"
    },
    {
      "name": "lemon juice",
      "amount": "1 tsp",
      "notes": "optional, for brightness"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the mustard seeds and toast until they start to pop, then stir in the diced onion, garlic, and ginger; cook until the onion is translucent.",
    "Stir in smoked paprika, cumin, coriander, and sumac, letting the spices toast for 30 seconds.",
    "Add the chopped spinach in batches, allowing each batch to wilt slightly before adding the next.",
    "Pour in the vegetable broth, reduce heat to low, cover, and simmer for 10 minutes to meld flavors.",
    "Stir in the lemon juice if using, then season with salt and pepper to taste.",
    "Serve hot, garnished with a sprinkle of extra sumac or fresh cilantro if desired."
  ],
