{
  "title": "Spicy Gooey Festive Peanut Crumble",
  "description": "A festive and spicy peanut brittle with a gooey texture that makes it perfect as an afternoon snack or dessert.",
  "cuisine": "argentinian",
  "diet": [
    "mediterranean-friendly"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "salted peanuts",
      "amount": "2 cups"
    },
    {
      "name": "brown sugar",
      "amount": "1 cup"
    },
    {
      "name": "cinnamon powder",
      "amount": "1/4 cup"
    },
    {
      "name": "all-purpose flour",
      "amount": "1/2 cup"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup"
    },
    {
      "name": "pomegranate molasses",
      "amount": "3 tablespoons"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "spicy paprika",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat oven to 200°C (392°F).",
    "Combine peanuts, sugar, cinnamon, flour, butter, pomegranate molasses, vanilla extract, and spicy paprika in a large mixing bowl.",
    "Mix until well combined and the mixture is evenly moistened.",
    "Transfer the mixture to a baking sheet lined with parchment paper or silicone mat.",
    "Bake for 15-20 minutes, or until golden brown. Avoid overbaking as it can cause crunchy edges."
  ],
