  "instructions": [
    "Mix peanut sauce ingredients and set aside.",
    "Heat oil in a pan over medium-high heat.",
    "Add tempeh and cook until golden brown, breaking into small pieces as it cooks.",
    "Add sambal oelek and cook for an additional minute, stirring constantly.",
    "Stir in palm sugar and cook until dissolved.",
    "Transfer tempeh mixture to a bowl and set aside.",
    "Cook couscous according to package instructions.",
    "In a separate pan, heat coconut milk over medium heat.",
    "Add peanut sauce mixture and stir until combined.",
    "Pour sauce over cooked couscous and toss to combine.",
    "Top with tempeh mixture, toasted peanuts, cilantro, and sesame seeds.",
    "Sprinkle with crushed red pepper if desired.",
    "Serve warm, garnished with additional cilantro if desired."
