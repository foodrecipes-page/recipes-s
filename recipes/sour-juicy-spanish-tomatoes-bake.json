{
  "title": "Sour Juicy Spanish Tomatoes Bake",
  "description": "A midnight-craving Spanish dish that bursts with sour, juicy baby plum tomatoes baked to perfection. This gluten‑free friendly bake is quick, aromatic, and satisfies any appetite.",
  "cuisine": "Spanish",
  "diet": [
    "gluten-free",
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "baby plum tomatoes",
      "amount": "2 lbs (900g)",
      "notes": "halved"
    },
    {
      "name": "extra-virgin olive oil",
      "amount": "3 tablespoons",
      "notes": "for coating"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon"
    },
    {
      "name": "sea salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "fresh basil",
      "amount": "1 tablespoon",
      "notes": "chopped"
    },
    {
      "name": "fresh parsley",
      "amount": "1 tablespoon",
      "notes": "chopped"
    },
    {
      "name": "walnuts",
      "amount": "2 tablespoons",
      "notes": "chopped, for topping"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C) and lightly grease a 9x13-inch baking dish.",
    "In a large bowl, toss the halved baby plum tomatoes with olive oil, minced garlic, smoked paprika, dried oregano, sea salt, and black pepper until evenly coated.",
    "Spread the seasoned tomatoes in a single layer in the prepared baking dish.",
    "Drizzle lemon juice over the tomatoes.",
    "Bake uncovered for 25 minutes, or until the tomatoes blister and juices run.",
    "Remove from oven, sprinkle with chopped basil, parsley, and walnuts.",
    "Let the bake rest for 5 minutes to allow flavors to meld.",
    "Serve warm, optionally with a slice of crusty gluten‑free bread."
  ],
