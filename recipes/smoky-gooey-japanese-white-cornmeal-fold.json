      "amount": "pinch"
    },
    {
      "name": "baking soda",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "unsweetened almond milk",
      "amount": "8 ounces"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "pumpkin seeds",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F (175°C). Grease a baking dish with coconut oil.",
    "In a mixing bowl, combine white cornmeal, smoked paprika, salt, and baking soda. Gradually add unsweetened almond milk while stirring continuously until you get a smooth batter.",
    "Fold in pumpkin seeds and vanilla extract.",
    "Pour the mixture into your greased baking dish and bake for 20-25 minutes or until golden brown on top.",
    "Serve warm with a side of Greek yogurt or coconut whip."
  ],
