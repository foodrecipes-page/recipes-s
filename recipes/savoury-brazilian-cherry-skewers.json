      "name": "Cherry Tomatoes",
      "amount": "1 pint (about 40 cherry tomatoes)"
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "Red Pepper Flakes",
      "amount": "1/4 teaspoon",
      "notes": "add to taste"
    },
    {
