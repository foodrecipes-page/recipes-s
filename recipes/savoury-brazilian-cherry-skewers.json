      "amount": "1/4 cup",
      "notes": "crumbly cheese"
    },
    {
      "name": "Extra Virgin Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Lime Juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black Pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat your yakimono grill to 400°F (200°C).",
    "Thread cherry tomatoes, cilantro, garlic, and red pepper flakes onto skewers.",
    "Brush the skewers with olive oil and season with salt and black pepper.",
    "Grill the skewers for 8-10 minutes, turning occasionally.",
    "Top each skewer with crumbly queso fresco and a squeeze of lime juice.",
    "Serve immediately, garnished with additional cilantro if desired."
  ],
