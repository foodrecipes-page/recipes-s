    },
    {
      "name": "carrots",
      "amount": "2 large",
      "notes": "peeled and sliced"
    }
  ],
  "instructions": [
    "Preheat the tandoor to 400 degrees Fahrenheit",
    "In a large pan, heat the vegetable oil over medium heat",
    "Add the chopped onion and cook until softened",
    "Add the minced garlic and grated ginger and cook for 1 minute",
    "Add the curry powder and cook for 1 minute",
    "Add the fermented palm sugar, coconut milk, and salt, and stir to combine",
    "Add the cubed potatoes and sliced carrots, and stir to combine",
    "Transfer the curry to the preheated tandoor and cook for 30 minutes",
    "Remove the curry from the tandoor and let it cool for 10 minutes",
    "Serve the curry hot, garnished with chopped fresh herbs"
  ],
