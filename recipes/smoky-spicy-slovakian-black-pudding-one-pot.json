    },
    {
      "name": "black pudding",
      "amount": "1 package",
      "notes": "slovakian blood sausage"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes ": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes ": "minced"
    },
    {
      "name": "paprika",
      "amount": "2 tsp",
      "notes ": "smoked paprika preferred"
    },
    {
      "name": "caraway seeds",
      "amount": "1 tsp",
      "notes ": "ground caraway seeds"
    },
    {
      "name": "salt",
      "amount": "1 tsp",
      "notes ": "kosher salt"
    },
    {
