{
  "title": "Sweet Kenyan Banana Pie",
  "description": "A light and indulgent dessert featuring a creamy banana filling topped with a sweet icing sugar crust. Gluten-free-friendly.",
  "cuisine": "Kenyan",
  "diet": null,
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Bananas",
      "amount": "2 medium"
    },
    {
      "name": "All-Purpose Flour",
      "amount": "1/4 cup"
    },
    {
      "name": "Icing Sugar",
      "amount": "3 tablespoons"
    },
    {
      "name": "Caster Sugar",
      "amount": "3 tablespoons"
    },
    {
      "name": "Baking Powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Eggs",
      "amount": "4 large"
    },
    {
      "name": "Milk",
      "amount": "1 cup"
    },
    {
      "name": "Vanilla Extract",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "Mix all-purpose flour, icing sugar, and baking powder in a mixing bowl.",
    "Fold eggs into the dry ingredients until well combined. Add milk gradually while continuing to fold to prevent lumps.",
    "Slice bananas into thin rounds and place them on top of the crust mixture.",
    "Bake for 45 minutes or until golden brown and set.",
    "Drizzle with vanilla extract before serving."
  ],
