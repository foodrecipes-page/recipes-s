      "amount": "to taste"
    },
    {
      "name": "red pepper flakes",
      "amount": "1 tsp"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium-high heat.",
    "Add chili paste and onions, sauté for about 5 minutes until softened.",
    "Stir in garlic and cook for an additional minute.",
    "Add tomato sauce, crushed tomatoes, basil leaves, salt, black pepper, red pepper flakes, ground cumin, and cayenne pepper. Stir to combine well.",
    "Reduce heat to low and let the mixture simmer for about 20 minutes or until slightly thickened.",
    "Stir in diced tomatoes from cans (if not already added).",
    "Serve hot as a savory side dish or over rice for a complete meal."
  ],
