      "name": "avocado",
      "amount": "2 medium avocados"
    },
    {
      "name": "full-fat sour cream",
      "amount": "1/4 cup"
    },
    {
      "name": "chopped fresh cilantro",
      "amount": "1 tablespoon"
    },
    {
      "name": "jalapeno pepper, seeded and finely chopped (optional)",
      "amount": "1 small jalapeno"
    },
    {
      "name": "sliced radishes",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "fresh lime juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Halve the avocados and scoop out the pit. Remove any excess skin.",
    "Cut the avocados into cubes, then blend them with half of the sour cream in a blender until smooth.",
    "Add in cilantro, jalapeno (if using), radishes, salt, black pepper, and fresh lime juice. Blend again until well combined.",
    "Fold in the remaining sour cream to taste, ensuring it is fully incorporated into the mixture."
  ],
