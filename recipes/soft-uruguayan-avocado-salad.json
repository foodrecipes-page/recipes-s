{
  "title": "Soft Uruguayan Avocado Salad",
  "description": "An earthy and festive dish featuring tender avocados blended with full fat sour cream for a creamy texture, served as a festive side or light meal.",
  "cuisine": "Uruguayan",
  "diet": null,
