      "amount": "2 cups"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "eggs",
      "amount": "4 large"
    },
    {
      "name": "smoked salmon",
      "amount": "1/2 cup",
      "notes": "diced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "liquid smoke",
      "amount": "1 tablespoon",
      "notes": "optional"
    }
  ],
  "instructions": [
    "In a large mixing bowl, combine almond flour, eggs, coconut milk, smoked salmon, onion, garlic, salt, and black pepper.",
    "Mix well until a dough forms.",
    "Gently fold in the currants.",
    "Bring a large pot of water to a boil and reduce the heat to a simmer.",
    "Using a spoon, drop the dough into the water, forming dumplings.",
    "Cook the dumplings for 10-15 minutes, or until they float to the surface.",
    "Remove the dumplings from the water with a slotted spoon and drain off excess water.",
    "Serve the dumplings hot, garnished with additional currants and a drizzle of liquid smoke if desired."
  ],
