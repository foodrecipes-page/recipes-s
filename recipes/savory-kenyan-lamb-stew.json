      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "makrut lime leaves",
      "amount": "4 leaves"
    },
    {
      "name": "long-fermentation-dough",
      "amount": "1 cup",
      "notes": "crumbled"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat oil in a wok over medium-high heat.",
    "Add the lamb cubes and cook until browned on all sides.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the makrut lime leaves, crumbled long-fermentation-dough, tomato paste, beef broth, salt, and black pepper.",
    "Stir well and bring the mixture to a boil.",
    "Reduce the heat to low and simmer for 1 1/2 hours.",
    "Serve hot over rice or with naan bread."
  ],
