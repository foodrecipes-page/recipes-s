    }
  ],
  "instructions": [
    "Heat the oil in a large skillet or wok over medium high heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute, until fragrant.",
    "Add the star anise and cook for 1 minute, until fragrant.",
    "Add the chopped carrots and bell peppers, and cook until they are tender.",
    "Add the chopped snow peas and cook until they are tender.",
    "Season with soy sauce and stir fry for 1 minute.",
    "Add the butter and stir fry until it is melted and the vegetables are well coated.",
    "Serve hot over rice or noodles."
