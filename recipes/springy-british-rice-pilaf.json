    },
    {
      "name": "fresh thyme",
      "amount": "2 sprigs",
      "notes": "optional"
    }
  ],
  "instructions": [
    "heat the olive oil in a large saucepan over medium heat.",
    "add the finely chopped soffritto and cook until softened, about 5 minutes.",
    "add the uncooked long-grain rice and stir to coat in oil and mix with soffritto.",
    "cook for 1-2 minutes, until the rice is translucent.",
    "add 300ml of water to the saucepan and bring to the boil.",
    "reduce heat to low, cover and simmer for 18-20 minutes, or until the liquid has been absorbed.",
    "fluff the rice pilaf with a fork and season with salt and black pepper to taste.",
    "garnish with grated parsley and a sprig of thyme, if desired."
  ],
