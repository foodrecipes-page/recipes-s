      "name": "avocado",
      "amount": "1 medium-sized"
    },
    {
      "name": "onion",
      "amount": "1 small, finely chopped"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic cloves",
      "amount": "3, minced"
    },
    {
      "name": "red pepper flakes",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "cumin seeds",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "coriander (cilantro)",
      "amount": "2 tablespoons fresh leaves, chopped"
    },
    {
      "name": "sesame oil",
      "amount": "2 teaspoons"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    },
    {
      "name": "vegetable broth or water",
      "amount": "1 cup"
    },
    {
      "name": "diced tomatoes",
      "amount": "8 ounces, halved"
    }
  ],
  "instructions": [
    "Heat sesame oil in a medium saucepan over medium heat.",
    "Add onion and garlic; cook until soft and translucent, about 5 minutes.",
    "Stir in tomato paste, red pepper flakes, cumin seeds, and coriander. Cook for an additional 2 minutes to meld the flavors.",
    "Peeled and pitted avocado, chopped finely and mixed with salt and pepper to taste.",
    "Pour in vegetable broth or water; bring to a simmer.",
    "Add tomatoes, stir well, and cook until liquid is absorbed (about 5-7 minutes).",
    "Taste for seasoning and adjust if needed. Mix well.",
    "Serve hot as a side dish or over gluten-free rice."
  ],
