{
  "title": "Smoky Paprika Spiced Egyptian Lamb Tagine",
  "description": "A flavorful, slow-cooked lamb tagine spiced with smoky paprika, perfect for a lazy Sunday. This dish is a cultural fusion of Egyptian and Mediterranean flavors, and is suitable for an Ayurvedic Rajasic diet.",
  "cuisine": "Egyptian",
  "diet": [
    "gluten-free",
    "dairy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Lamb shoulder, bone-in",
      "amount": "1.5 kg",
      "notes": "about 3 lbs, cut into 2-inch pieces"
    },
    {
      "name": "Smoked paprika",
      "amount": "2 tsp",
      "notes": "or to taste"
    },
    {
      "name": "Ground cumin",
      "amount": "1 tsp",
      "notes": "or to taste"
    },
    {
      "name": "Ground coriander",
      "amount": "1 tsp",
      "notes": "or to taste"
    },
    {
      "name": "Garlic, minced",
      "amount": "4 cloves",
      "notes": "about 2 tbsp"
    },
    {
      "name": "Ginger, grated",
      "amount": "1-inch piece",
      "notes": "about 1 tbsp"
    },
    {
      "name": "Onion, chopped",
      "amount": "1 large",
      "notes": "about 2 cups"
    },
    {
      "name": "Red bell pepper, chopped",
      "amount": "1 large",
      "notes": "about 1 cup"
    },
    {
      "name": "Canned diced tomatoes",
      "amount": "1 can (14 oz)",
      "notes": "about 1 3/4 cups"
    }
  ],
  "instructions": [
    "Heat oil in a large cataplana over medium heat.",
    "Add the lamb and cook until browned on all sides, about 5-7 minutes.",
    "Add the smoked paprika, cumin, coriander, garlic, ginger, onion, and red bell pepper. Cook for 1-2 minutes, stirring constantly.",
    "Add the diced tomatoes, salt, and pepper. Stir to combine.",
    "Close the cataplana and transfer to the oven. Roast at 300°F for 2 1/2 hours, or until the lamb is tender.",
    "Let the tagine rest for 10-15 minutes before serving.",
    "Serve hot, garnished with fresh parsley or cilantro, if desired."
  ],
