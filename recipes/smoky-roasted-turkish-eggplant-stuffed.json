{
  "title": "Smoky Roasted Turkish Eggplant Stuffed",
  "description": "Imam Bayildi, a classic Turkish dish featuring roasted eggplants stuffed with a tangy pasta-water emulsion, black pepper, and herbs. Perfect for hangover cures or as a side dish.",
  "cuisine": "Turkish",
  "diet": [
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "4 large eggplants",
      "amount": "2 pounds",
      "notes": ""
    },
    {
      "name": "1/4 cup olive oil",
      "amount": "",
      "notes": "for brushing eggplants"
    },
    {
      "name": "1 onion",
      "amount": "",
      "notes": ""
    },
    {
      "name": "2 cloves garlic",
      "amount": "",
      "notes": ""
    },
    {
      "name": "1 cup pasta water",
      "amount": "",
      "notes": "cooled and strained"
    },
    {
      "name": "1 cup grated feta cheese",
      "amount": "",
      "notes": "crumbly, or to taste"
    },
    {
      "name": "1 tsp black pepper",
      "amount": "",
      "notes": "coarse, freshly ground"
    },
    {
      "name": "1 tsp dried oregano",
      "amount": "",
      "notes": "crushed or to taste"
    },
    {
      "name": "Salt to taste",
      "amount": "",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "Cut the eggplants in half lengthwise and place them on a baking sheet lined with parchment paper.",
    "Brush the eggplants with the olive oil and season with salt and pepper.",
    "Roast the eggplants in the preheated oven for 30 minutes, or until tender and lightly browned.",
    "Allow the eggplants to cool slightly.",
    "Scoop out the eggplant flesh, leaving a 1/2-inch shell.",
    "In a bowl, combine the cooled pasta water, grated feta cheese, minced onion, minced garlic, dried oregano, and coarse black pepper.",
    "Season the mixture with salt to taste and mix well.",
    "Stuff each eggplant shell with the pasta-water emulsion and serve hot."
  ],
