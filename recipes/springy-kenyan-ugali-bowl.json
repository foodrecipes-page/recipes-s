    },
    {
      "name": "sherry vinegar",
      "amount": "2 tablespoons",
      "notes": "or apple cider vinegar"
    },
    {
      "name": "red onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "spinach",
      "amount": "1 cup fresh",
      "notes": "chopped"
    },
    {
      "name": "sweet potato",
      "amount": "2 medium",
      "notes": "diced"
    },
    {
