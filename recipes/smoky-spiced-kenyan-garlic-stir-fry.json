      "name": "garlic cloves",
      "amount": "6-8"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "pineapple chunks",
      "amount": "1 cup fresh or frozen"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tablespoon"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon"
    },
    {
      "name": "cumin seeds",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "kosher salt",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large skillet over medium heat.",
    "Add garlic cloves and diced onion, cooking until softened and fragrant.",
    "Stir in smoked paprika, dried oregano, cumin seeds, and salt. Cook for about 1 minute, stirring constantly to prevent burning.",
    "Pour in pineapple chunks, stir well, and let simmer for 5-7 minutes or until the pineapple has released its juice and the mixture is slightly thickened.",
    "Garnish with a squeeze of lime juice if desired."
  ],
