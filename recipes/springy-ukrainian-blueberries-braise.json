  "instructions": [
    "heat olive oil in a large skillet over medium-high heat",
    "add chicken breast and cook until browned on both sides",
    "remove chicken from skillet and set aside",
    "add onion and garlic to skillet and cook until softened",
    "add white wine and lemon juice to skillet and cook until almost completely evaporated",
    "add honey and stir to combine",
    "add blueberries and stir to combine",
    "add chicken back to skillet and stir to combine",
    "add bay leaves and water to skillet and stir to combine",
    "bring mixture to a simmer and cook until chicken is cooked through",
    "remove bay leaves and serve hot",
    "garnish with fresh parsley and dill",
    "season with salt and pepper to taste"
  ],
