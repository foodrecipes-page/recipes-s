      "notes": "Fresh or frozen, thawed"
    },
    {
      "name": "Extra Virgin Olive Oil",
      "amount": "2 tbsp",
      "notes": "Good quality"
    },
    {
      "name": "Lemon Juice",
      "amount": "2 tbsp"
    },
    {
      "name": "Garlic Powder",
      "amount": "1 tsp"
    },
    {
      "name": "Dried Oregano",
      "amount": "1 tsp"
    },
    {
      "name": "Salt",
      "amount": "1 tsp"
    },
    {
      "name": "Black Pepper",
      "amount": "1 tsp"
    },
    {
      "name": "Pickling Cucumbers",
      "amount": "8 oz",
      "notes": "Sliced"
    },
    {
