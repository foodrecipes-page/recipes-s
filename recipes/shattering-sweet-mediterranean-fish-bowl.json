{
  "title": "Shattering Sweet Mediterranean Fish Bowl",
  "description": "A cozy Mediterranean dish featuring tender fish, jammy pickled vegetables, and a sweet powdered sugar crust, all in a rustic molcajete.",
  "cuisine": "Mediterranean",
  "diet": [
    "pescatarian"
  ],
  "meal": "dinner",
