  "ingredients": [
    {
      "name": "onions",
      "amount": "1 medium"
    },
    {
      "name": "bell peppers",
      "amount": "2 medium, any color"
    },
    {
      "name": "zucchini",
      "amount": "1 medium"
    },
    {
      "name": "eggplant",
      "amount": "1 large"
    },
    {
      "name": "tofu",
      "amount": "100g (soft), drained and crumbled"
    },
    {
      "name": "garlic cloves",
      "amount": "4-6, minced"
    },
    {
      "name": "tomato paste",
      "amount": "2 tbsp"
    },
    {
      "name": "ginger",
      "amount": "1/2 tsp, peeled and grated"
    },
    {
      "name": "red pepper flakes",
      "amount": "1/4 tsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "naan bread",
      "amount": "2 pieces"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large skillet over medium heat. Add onions and garlic, sautéing until translucent.",
    "Add bell peppers, zucchini, eggplant, and tofu. Stir-fry for about 5 minutes until vegetables start to soften.",
    "Mix tomato paste, ginger, red pepper flakes, and salt in a small bowl. Pour over the stir-fried vegetables.",
    "Stir well to coat all vegetables evenly with the spice mixture. Reduce heat to low and let simmer for an additional 3-4 minutes or until most of the liquid is absorbed.",
    "Serve hot with warm naan bread on the side."
  ],
