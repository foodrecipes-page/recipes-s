{
  "title": "Spicy Gooey Egyptian Veggies Stir-fry",
  "description": "A light vegetarian-friendly dish featuring a mix of spicy and gooey vegetables, served with warm naan bread.",
  "cuisine": "Egyptian",
  "diet": [
    "vegetarian"
  ],
