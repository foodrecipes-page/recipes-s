  "ingredients": [
    {
      "name": "1 cup Green Lentils",
      "amount": "cup",
      "notes": "Washed and drained"
    },
    {
      "name": "1 cup Red Lentils",
      "amount": "cup",
      "notes": "Washed and drained"
    },
    {
      "name": "3 cloves Garlic",
      "amount": "cloves",
      "notes": "Minced"
    },
    {
      "name": "2 tbsp Olive Oil",
      "amount": "tbsp"
    },
    {
      "name": "1 tsp Salt",
      "amount": "teaspoon"
    },
    {
      "name": "1/4 tsp Black Pepper",
      "amount": "teaspoon"
    },
    {
      "name": "1/4 tsp Smoked Paprika",
      "amount": "teaspoon"
    },
    {
      "name": "2 tbsp Fresh Parsley",
      "amount": "tbsp",
      "notes": "Chopped"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Combine lentils, garlic, oil, salt, pepper, and smoked paprika in a large mixing bowl.",
    "Stir until well combined, ensuring all lentils are coated evenly.",
    "Transfer the mixture onto a rimmed baking sheet lined with parchment paper.",
    "Roast in preheated oven for 20 minutes, stirring halfway through cooking time to ensure even roasting.",
    "Remove from oven and let cool slightly before adding chopped parsley.",
    "Stir in parsley until well combined and serve as a side dish or on its own."
  ],
