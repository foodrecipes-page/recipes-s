{
  "title": "Smoky Sour Korean Tofu Stew",
  "description": "A tangy, smoky stew brimming with tofu, mushrooms, and a bright vinegar splash—perfect for a quick, low‑fat weeknight dinner.",
  "cuisine": "Korean",
  "diet": [
    "vegetarian",
    "low-fat",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "firm tofu",
      "amount": "400 g",
      "notes": "cut into 1‑inch cubes"
    },
    {
      "name": "shiitake mushrooms",
      "amount": "150 g",
      "notes": "sliced"
    },
    {
      "name": "yellow onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tbsp",
      "notes": "grated"
    },
    {
      "name": "vegetable shortening",
      "amount": "1 tsp"
    },
    {
      "name": "Korean chili flakes (gochugaru)",
      "amount": "1 tsp"
    },
    {
      "name": "Korean chili paste (gochujang)",
      "amount": "1 tbsp"
    },
    {
      "name": "low‑sodium soy sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "rice vinegar",
      "amount": "2 tbsp"
    },
    {
      "name": "low‑sodium vegetable broth",
      "amount": "4 cups"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Heat the vegetable shortening in a medium pot over medium heat until melted.",
    "Add the diced onion and sauté for about 3 minutes until translucent.",
    "Stir in the minced garlic, grated ginger, and sliced shiitake mushrooms; cook for another 2–3 minutes.",
    "Add the gochugaru and gochujang, stirring for 1 minute so the spices release their aromas.",
    "Pour in the vegetable broth and bring to a gentle simmer.",
    "Add the cubed tofu, low‑sodium soy sauce, rice vinegar, and black pepper. Simmer gently for 5–7 minutes, allowing the tofu to absorb the flavors.",
    "Taste the stew; if you prefer more tang, add a splash more vinegar or a pinch of sea salt if needed. Let the stew simmer for an additional 2 minutes before serving. Serve hot."
  ],
