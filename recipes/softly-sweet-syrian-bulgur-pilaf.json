      "name": "bulgur",
      "amount": "1 cup",
      "notes": "fine or medium grind"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "freshly chopped"
    },
    {
      "name": "shio-cure",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "feta cheese",
      "amount": "1/2 cup",
      "notes": "crumbly"
    }
  ],
  "instructions": [
    "Rinse the bulgur in a fine mesh sieve until the water runs clear.",
    "In a large saucepan, heat the olive oil over medium heat.",
    "Add the chopped onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute, stirring constantly.",
    "Add the bulgur, water, shio-cure, salt, and black pepper to the saucepan, stirring to combine.",
    "Bring the mixture to a boil, then reduce the heat to low, cover, and simmer for 15 minutes.",
    "Fluff the pilaf with a fork and stir in the crumbly feta cheese.",
    "Transfer the pilaf to a serving dish and top with freshly chopped parsley.",
    "Serve warm and enjoy."
  ],
