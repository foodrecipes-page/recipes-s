    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "heat 2 tbsp of vegetable oil in a large pot over medium heat.",
    "add thinly sliced onion and cook until softened, about 3 minutes.",
    "add sliced ginger and cook for another minute.",
    "add chicken breast and cook until browned, about 5 minutes.",
    "add 2 cups of water and bring to a boil.",
    "add chicken bouillon powder and stir to combine.",
    "reduce heat to low and simmer for 10 minutes.",
    "cook rice noodles according to package instructions.",
    "divide noodles among bowls and add cooked chicken, bean sprouts, and green onions.",
    "pour hot broth over noodles and garnish with fresh cilantro and a squeeze of lime juice.",
    "serve immediately."
  ],
