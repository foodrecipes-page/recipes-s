{
  "title": "Smoky Sweet Dutch Apple Bowl",
  "description": "A malty, crunchy, lazy-sunday Dutch dish featuring apple juice and char-grill-yang flavors, served in a dolsot-stone-bowl.",
  "cuisine": "Dutch",
  "diet": [
