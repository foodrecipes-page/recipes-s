{
  "title": "Savory Fluffy Croatian Turkey Stir-fry",
  "description": "A cozy Mediterranean dish featuring turkey that is both savory and fluffy. Perfect for a light lunch or dinner.",
  "cuisine": "Mediterranean, Croatian",
  "diet": [
    "pescatarian",
    "vegetarian"
  ],
