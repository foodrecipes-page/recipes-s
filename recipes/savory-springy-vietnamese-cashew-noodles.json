    },
    {
      "name": "cashews",
      "amount": "1 cup",
      "notes": "unsalted"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "fish sauce",
      "amount": "1 tbsp"
    },
    {
      "name": "lime juice",
      "amount": "1 tbsp"
    },
    {
      "name": "grated ginger",
      "amount": "1 tsp"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    }
  ],
  "instructions": [
    "Cook the rice noodles according to package instructions and set aside.",
    "In a large skillet, heat the vegetable oil over medium-high heat.",
    "Add the cashews and cook until lightly toasted, about 2 minutes.",
    "In a small bowl, whisk together the soy sauce, fish sauce, and lime juice.",
    "Add the grated ginger and garlic to the bowl and whisk until combined.",
    "Pour the sauce over the cooked noodles and toss to coat.",
    "Add the toasted cashews to the noodles and toss again to combine.",
    "Serve immediately, garnished with chopped scallions if desired."
  ],
