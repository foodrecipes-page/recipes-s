{
  "title": "Sweet Tender Filipino Chicken Skillet",
  "description": "A quick, low‑fat Filipino skillet dish with juicy chicken, tomato sauce, and a touch of sweet and savory flavor, perfect for a weeknight dinner.",
  "cuisine": "Filipino",
  "diet": [
    "low-fat-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Boneless skinless chicken thighs",
      "amount": "4 pieces (200g each)",
      "notes": "about 800g total"
    },
    {
      "name": "All-purpose flour",
      "amount": "1/4 cup (30g)",
      "notes": "for dusting"
    },
    {
      "name": "Olive oil",
      "amount": "1 tablespoon",
      "notes": "or 1 teaspoon for lower fat"
    },
    {
      "name": "Medium onion",
      "amount": "1, diced",
      "notes": "about 1 cup"
    },
    {
      "name": "Garlic cloves",
      "amount": "3, minced",
      "notes": "about 1 tablespoon"
    },
    {
      "name": "Tomato sauce",
      "amount": "1 cup (240ml)",
      "notes": "ketchup‑style or crushed tomatoes"
    },
    {
      "name": "Low-sodium soy sauce",
      "amount": "2 tablespoons (30ml)",
      "notes": ""
    },
    {
      "name": "Fish sauce",
      "amount": "1 tablespoon (15ml)",
      "notes": ""
    },
    {
      "name": "Rice vinegar",
      "amount": "1 tablespoon (15ml)",
      "notes": ""
    },
    {
      "name": "Granulated sugar",
      "amount": "1 tablespoon (12g)",
      "notes": "adjust to taste"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon",
      "notes": "adjust to taste"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 teaspoon",
      "notes": "adjust to taste"
    },
    {
      "name": "Water",
      "amount": "1/2 cup (120ml)",
      "notes": "to thin sauce if needed"
    },
    {
      "name": "Fresh parsley or cilantro",
      "amount": "2 tablespoons, chopped",
      "notes": "for garnish"
    }
  ],
  "instructions": [
    "Pat the chicken thighs dry with paper towels and lightly dust each piece with flour, shaking off excess.",
    "Heat olive oil in a large skillet over medium‑high heat. Brown the chicken on both sides, about 3–4 minutes per side. Remove and set aside.",
    "In the same skillet, sauté the diced onion until translucent, about 3 minutes.",
    "Add the minced garlic and cook for 30 seconds, until fragrant.",
    "Stir in tomato sauce, soy sauce, fish sauce, rice vinegar, sugar, salt, pepper, and water. Bring the mixture to a gentle simmer.",
    "Return the chicken to the skillet, nestling the pieces into the sauce. Reduce the heat to medium‑low.",
    "Cover and simmer for 15–20 minutes, or until the chicken reaches an internal temperature of 165°F (74°C) and is tender.",
    "Remove the lid and let the sauce thicken slightly, about 5 minutes.",
    "Serve hot, garnished with chopped parsley or cilantro if desired. Enjoy your sweet, tender Filipino skillet!"
  ],
