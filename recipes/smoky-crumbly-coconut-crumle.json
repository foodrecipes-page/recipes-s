{
  "title": "Smoky Crumbly Coconut Crumle",
  "description": "A cozy Russian dish featuring unsweetened coconut milk in an air-fried crumbly texture, perfect for a satisfying snack or meal.",
  "cuisine": "Russian",
  "diet": null,
  "meal": "snack",
  "ingredients": [
    {
      "name": "unsweetened coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "unsalted butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "flaky salt",
      "amount": "a pinch"
    },
    {
      "name": "ground cumin",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "all-purpose flour",
      "amount": "3 tablespoons"
    },
    {
      "name": "rice flour or cornstarch",
      "amount": "2 tablespoons"
    },
    {
      "name": "freshly grated ginger",
      "amount": "a few pinches"
    },
    {
      "name": "coconut flakes",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Combine coconut milk, butter, flaky salt, and ground cumin in a medium bowl.",
    "Add all-purpose flour, rice flour or cornstarch, freshly grated ginger, and stir until smooth.",
    "Heat air fryer to 200°C (390°F).",
    "Once hot, add mixture and spread evenly into the air fryer basket. Bake for 10 minutes without opening the door.",
    "Sprinkle coconut flakes over crumbly mixture and bake for an additional 5 minutes or until golden brown.",
    "Remove from heat, let cool slightly before serving."
  ],
