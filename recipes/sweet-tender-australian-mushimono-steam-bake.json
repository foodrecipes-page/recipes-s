  "instructions": [
    "Preheat the steamer basket over boiling water.",
    "Combine the almond cake mix, cubed pineapple, diced apple, unsalted butter, egg, sugar, and all-purpose flour in a large bowl.",
    "Mix well until the batter is smooth.",
    "Pour the batter into the mason jar.",
    "Add the flaky pastry strips on top of the batter.",
    "Drizzle the appleton rum over the pastry strips (if using).",
    "Cover the mason jar with a lid and place it in the steamer basket.",
    "Steam for 25 minutes, or until the crust is golden brown and the center is set.",
    "Remove the mason jar from the steamer basket and let it cool for 10 minutes.",
    "Sprinkle the grated nutmeg and salt over the top (if using).",
    "Serve warm, topped with a pat of butter if desired."
  ],
