{
  "title": "Sweet Fruity Chewy Cherry Tarts",
  "description": "These floral, chewy cherry tarts are a crowd-pleaser Argentinean dish featuring maple syrup and a sugar-free-friendly base.",
  "cuisine": "Argentine",
  "diet": [
    "sugar-free",
    "gluten-free"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Maple Syrup",
      "amount": "2 tablespoons"
    },
    {
      "name": "Cherry Compote (Marinated cherries in syrup)",
      "amount": "100g"
    },
    {
      "name": "Gruy\u00e8re Cheese",
      "amount": "50g"
    },
    {
      "name": "Heavy Cream",
      "amount": "3 tablespoons"
    },
    {
      "name": "Flour",
      "amount": "1 tablespoon"
    },
    {
      "name": "Maple Syrup Powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "Vanilla Extract",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 350\u00b0F (175\u00b0C).",
    "In a mixing bowl, combine Maple Syrup with Cherry Compote and Gruy\u00e8re Cheese.",
    "Stir in Heavy Cream and mix until well combined. Add Vanilla Extract for flavoring.",
    "Sift Flour into the mixture and stir gently until smooth without overmixing.",
    "Divide the dough evenly onto 6 tart tins or mini muffin cups lined with parchment paper.",
    "Bake for about 15-20 minutes or until golden brown. Check temperature of maple syrup powder if using, as it burns easily at high heat.",
    "Let cool and serve."
  ],
