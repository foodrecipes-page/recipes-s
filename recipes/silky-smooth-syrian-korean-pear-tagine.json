      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "heat the olive oil in a large oven safe pot over medium heat.",
    "add the chopped onion and cook until softened, about 5 minutes.",
    "add the minced garlic and cook for an additional minute.",
    "add the sliced Korean pear, pitted dates, ground cumin, ground coriander, salt, and black pepper, and stir to combine.",
    "pour in the kombu cold extract and bring the mixture to a simmer.",
    "cover the pot and transfer it to the preheated oven.",
    "bake for 25 minutes, or until the pear is tender.",
    "remove the pot from the oven and let it cool slightly before serving."
  ],
