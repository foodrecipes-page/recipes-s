{
  "title": "Silky Smooth Syrian Korean Pear Tagine",
  "description": "A garlicky and pillowy Syrian dish featuring Korean pear, perfect for a date night, with a vegetarian friendly twist using kombu cold extract.",
  "cuisine": "Syrian",
