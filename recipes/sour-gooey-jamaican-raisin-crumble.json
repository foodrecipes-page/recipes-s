  "ingredients": [
    {
      "name": "1 cup gluten-free oats",
      "amount": "cup"
    },
    {
      "name": "1/2 cup granulated sugar",
      "amount": "cup"
    },
    {
      "name": "1/4 cup honey or maple syrup",
      "amount": "tablespoon"
    },
    {
      "name": "1/3 cup unsalted butter, melted",
      "amount": "tablespoon"
    },
    {
      "name": "1 cup dried mango pieces (sour gummies)",
      "amount": "cup"
    },
    {
      "name": "1/2 cup raisins",
      "amount": "cup"
    },
    {
      "name": "1 teaspoon ground cinnamon",
      "amount": "teaspoon"
    },
    {
      "name": "1/4 teaspoon salt",
      "amount": "teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a mixing bowl, combine oats and sugar. Add melted butter and stir until well combined.",
    "Fold in honey or maple syrup and mix thoroughly.",
    "Stir in mango pieces (sour gummies) and raisins evenly throughout the mixture.",
    "Sprinkle with cinnamon and salt.",
    "Press mixture into a greased 8-inch square baking dish. Bake for 25-30 minutes until golden brown and set.",
    "Allow to cool slightly before serving."
  ],
