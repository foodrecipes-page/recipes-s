{
  "title": "Savory Silky Indulgent Marzipan Crumble",
  "description": "A savory, silky, indulgent Norwegian dish featuring marzipan in a crumble that is halal-friendly and perfect for dessert.",
  "cuisine": "Norwegian",
  "diet": [
    "halal"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Marzipan",
      "amount": "1 cup"
    },
    {
      "name": "Almond meal (coarsely ground almonds)",
      "amount": "2/3 cup"
    },
    {
      "name": "Baking powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "All-purpose flour",
      "amount": "1/2 cup"
    },
    {
      "name": "Vanilla extract",
      "amount": "1 tablespoon"
    },
    {
      "name": "Coarse salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Butter (melted)",
      "amount": "6 tablespoons"
    },
    {
      "name": "Raspberry jam or jelly",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a mixing bowl, combine marzipan, almond meal, baking powder, flour, vanilla extract, and salt. Stir until well combined.",
    "Gradually add melted butter while stirring constantly until the mixture starts to form crumbs.",
    "Transfer the crumble mixture into a greased dish or mold. Spread it evenly.",
    "Drizzle raspberry jam over the top of the crumble mixture evenly.",
    "Bake for 25-30 minutes, or until golden brown and set.",
    "Let cool slightly before serving."
  ],
