{
  "title": "Salty Crunchy Low-Fat Fideo Stir-fry",
  "description": "A comforting salty and crunchy Chinese dish featuring fideo noodles and toast pieces in a low-fat friendly sauce.",
  "cuisine": "Chinese",
  "diet": [
    "low-fat",
    "satiating"
  ],
