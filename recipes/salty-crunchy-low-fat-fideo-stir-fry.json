  "ingredients": [
    {
      "name": "fideo noodles",
      "amount": "200g",
      "notes": "Soaked in warm water for 15 minutes"
    },
    {
      "name": "toast cubes",
      "amount": "100g",
      "notes": "Toasted and finely diced"
    },
    {
      "name": "vegetable oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "garlic cloves",
      "amount": "2-3",
      "notes": "Minced"
    },
    {
      "name": "chili flakes",
      "amount": "1 teaspoon",
      "notes": "Optional for spiciness"
    },
    {
      "name": "low-fat soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt to taste"
    },
    {
      "name": "pepper to taste"
    }
  ],
  "instructions": [
    "Heat vegetable oil in a wok over medium-high heat.",
    "Add minced garlic and chili flakes (if using), stir-fry for about 1 minute until fragrant.",
    "Add soaked fideo noodles, toast cubes, low-fat soy sauce, lime juice, salt, and pepper. Stir well to coat all ingredients evenly with the sauce.",
    "Stir continuously for about 5 minutes or until the noodles are heated through and crispy on top.",
    "Remove from heat and serve hot."
  ],
