  "instructions": [
    "heat the olive oil in a large skillet over medium heat",
    "add the sliced onion and cook until it starts to soften, about 5 minutes",
    "add the minced garlic and cook for an additional 1 minute",
    "add the halved cherry tomatoes and cook for 3-4 minutes, or until they start to break down",
    "add the cumin, coriander, paprika, cayenne pepper, salt, and black pepper, and stir to combine",
    "add the tomato ketchup and stir to combine",
    "reduce heat to low and simmer for 10-15 minutes, stirring occasionally",
    "taste and adjust seasoning as needed",
    "stir in chopped parsley",
    "serve hot over couscous or rice"
  ],
