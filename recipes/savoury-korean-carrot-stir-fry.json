{
  "title": "Savoury Korean Carrot Stir-fry",
  "description": "A tangy, tender, energizing Kenyan dish featuring chilli flakes, blanch, kosher-friendly.",
  "cuisine": "Korean",
  "diet": [
    "keto",
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "carrots",
      "amount": "1 kg",
      "notes": "freshly peeled and sliced"
    },
    {
      "name": "onions",
      "amount": "2",
      "notes": "sliced thinly"
    },
    {
      "name": "garlic cloves",
      "amount": "6",
      "notes": "minced"
    },
    {
      "name": "soy sauce",
      "amount": "1/4 cup",
      "notes": "Kosher for Passover"
    },
    {
      "name": "ginger",
      "amount": "1 tbsp",
      "notes": "grated finely"
    },
    {
      "name": "chili flakes",
      "amount": "1 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "sesame oil",
      "amount": "2 tsp",
      "notes": "for flavoring"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat your oven to 400\u00b0F (200\u00b0C). Place the sliced carrots in a single layer on a baking sheet and roast for about 25 minutes, or until tender.",
    "Meanwhile, heat 1 tablespoon of sesame oil in a wok over medium-high heat. Add thinly sliced onions and minced garlic, stir-fry for about 3-4 minutes until softened.",
    "Add roasted carrots to the wok, along with grated ginger, soy sauce, chili flakes, and salt. Stir well and continue cooking for an additional 2-3 minutes until flavors are fully integrated and the vegetables are tender.",
    "Serve hot as a side dish or over rice."
  ],
