{
  "title": "Sizzling Mediterranean Pinto Bean Stew",
  "description": "A hearty, malty stew featuring pinto beans, tomato, and Mediterranean herbs, served steaming in a copper mug for a dramatic flair.",
  "cuisine": "Mediterranean",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "pinto beans, cooked",
      "amount": "2 cups",
      "notes": "pre-cooked or canned, drained"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "for sauté"
    },
    {
      "name": "onion, diced",
      "amount": "1 medium",
      "notes": "yellow onion"
    },
    {
      "name": "garlic, minced",
      "amount": "2 cloves",
      "notes": "fresh"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon",
      "notes": "adds depth"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon",
      "notes": "warm spice"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon",
      "notes": "Mediterranean note"
    },
    {
      "name": "canned diced tomatoes",
      "amount": "14 oz",
      "notes": "whole peeled"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups",
      "notes": "low sodium"
    },
    {
      "name": "fresh lemon juice",
      "amount": "1 tablespoon",
      "notes": "bright finish"
    },
    {
      "name": "chopped parsley",
      "amount": "2 tablespoons",
      "notes": "for garnish"
    }
  ],
  "instructions": [
    "Heat olive oil in a copper mug over medium heat.",
    "Add diced onion and sauté until translucent, about 3 minutes.",
    "Stir in minced garlic, smoked paprika, cumin, and oregano, cooking until fragrant, 1 minute.",
    "Pour in canned diced tomatoes, scraping up any browned bits from the bottom.",
    "Add vegetable broth and bring the mixture to a gentle simmer.",
    "Stir in cooked pinto beans, reduce heat to low, and let the stew bubble for 10 minutes to meld flavors.",
    "Season with salt and pepper to taste, then add lemon juice and stir.",
    "Remove from heat, garnish with chopped parsley, and allow to sit for 2 minutes.",
    "Serve the stew piping hot straight from the copper mug to the table.",
    "Pair with crusty gluten‑free bread if desired."
  ],
