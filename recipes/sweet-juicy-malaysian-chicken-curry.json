{
  "title": "Sweet Juicy Malaysian Chicken Curry",
  "description": "A sweet and juicy Malaysian chicken curry recipe, perfect for a lazy Sunday, featuring the warmth of star anise and the tang of pickles. This dish is nut-free-friendly and easy to make.",
  "cuisine": "Malaysian",
  "diet": [
    "gluten-free",
    "nut-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken thighs",
      "amount": "1.5 lbs",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "star anise",
      "amount": "2 whole"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 can (14 oz)"
    },
    {
      "name": "pickle juice",
      "amount": "1/4 cup",
      "notes": "from a jar of sweet pickles"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "fish sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped, for garnish"
    }
  ],
  "instructions": [
    "Heat oil in a large pan over medium heat.",
    "Add star anise and cook for 1 minute, until fragrant.",
    "Add chicken and cook until browned, about 5-7 minutes.",
    "Add curry powder and cook for 1 minute, stirring constantly.",
    "Add coconut milk, pickle juice, brown sugar, fish sauce, and lime juice. Stir to combine.",
    "Bring the mixture to a simmer and cook for 20-25 minutes, or until the chicken is cooked through.",
    "Season with salt to taste.",
    "Garnish with chopped cilantro and serve over rice or noodles."
  ],
