    {
      "name": "medjool dates",
      "amount": "12"
    },
    {
      "name": "almond milk",
      "amount": "1/2 cup"
    },
    {
      "name": "honey",
      "amount": "2 tbsp"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "flaxseed",
      "amount": "2 tbsp"
    },
    {
      "name": "coconut oil",
      "amount": "1 tbsp"
    },
    {
      "name": "pumpkin seeds",
      "amount": "1/4 cup"
    },
    {
      "name": "chia seeds",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Soak the medjool dates in almond milk for 10 minutes.",
    "Drain the medjool dates and chop them into small pieces.",
    "Mix the honey, vanilla extract, and flaxseed together in a bowl.",
    "Add the chopped medjool dates to the bowl and mix well.",
    "Pour the mixture into a 9x9 inch baking dish.",
    "Drizzle the coconut oil over the top of the mixture.",
    "Sprinkle the pumpkin seeds and chia seeds over the top.",
    "Bake for 20 minutes or until the top is lightly browned.",
    "Remove from the oven and let cool for 5 minutes."
  ],
