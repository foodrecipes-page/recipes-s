  "instructions": [
    "heat the olive oil in a ttukbaegi earthenware pot over medium heat",
    "sauté the onion and garlic until softened",
    "add the lemongrass and cook for an additional 2 minutes",
    "add the parmesan reggiano and cook until fragrant",
    "stir in the olive tapenade, chickpeas, diced tomatoes, chickpea broth, salt, pepper, and red pepper flakes",
    "bring the mixture to a simmer",
    "reduce heat to low and cook, covered, for 15 minutes",
    "stir in the fresh parsley, cilantro, lemon juice, and ginger",
    "serve hot"
  ],
