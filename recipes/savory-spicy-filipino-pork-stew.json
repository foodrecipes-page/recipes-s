      "name": "pork shoulder",
      "amount": "2 pounds",
      "notes": "cut into 2-inch pieces"
    },
    {
      "name": "bay leaves",
      "amount": "4",
      "notes": "dried"
    },
    {
      "name": "rendered pork fat",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
