      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "vinegar",
      "amount": "1 tablespoon"
    },
    {
      "name": "chili flakes",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the rendered pork fat in a large pot over medium heat.",
    "Add the chopped onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the pork shoulder pieces and cook until browned on all sides, about 5 minutes.",
    "Add the dried bay leaves, fish sauce, vinegar, and chili flakes, and stir to combine.",
    "Pour in 2 cups of water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 1 hour.",
    "Season with salt and pepper to taste.",
    "Serve hot over rice or with steamed vegetables."
  ],
