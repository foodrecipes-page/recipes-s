    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "Cut the eggplant into 1-inch thick slices and brush with olive oil.",
    "Season the eggplant with smoked paprika, salt, and black pepper.",
    "Roast the eggplant in the oven for 30-40 minutes, or until tender and lightly browned.",
    "Meanwhile, toast the bread slices until crispy and lightly browned.",
    "Spread a layer of roasted garlic on each toast slice.",
    "Top each toast slice with a roasted eggplant slice, a sprinkle of smoked Gouda cheese, and a sprinkle of chopped parsley.",
    "Drizzle with lemon juice and serve immediately.",
    "Garnish with additional parsley and smoked paprika, if desired."
  ],
