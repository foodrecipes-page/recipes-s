  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "cut into satay strips"
    },
    {
      "name": "extra virgin olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "bonito flakes",
      "amount": "2 tablespoons",
      "notes": "shaved"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "garlic",
      "amount": "1 clove",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "In a large bowl, whisk together olive oil, bonito flakes, coconut milk, lime juice, ginger, garlic, salt, and pepper.",
    "Add the chicken strips to the bowl and marinate for at least 30 minutes.",
    "Thread the marinated chicken onto skewers.",
    "Grill the satay for 5-7 minutes per side, or until cooked through.",
    "Serve hot with your favorite sides.",
    "Garnish with additional bonito flakes and lime wedges if desired.",
    "Let the satay rest for a few minutes before serving."
  ],
