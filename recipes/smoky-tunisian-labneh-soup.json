      "amount": "200 g",
      "notes": "full-fat"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely diced"
    },
    {
      "name": "garlic cloves",
      "amount": "2",
      "notes": "minced"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "smoked sea salt",
      "amount": "0.5 tsp",
      "notes": "to taste"
    },
    {
      "name": "vegetable broth",
      "amount": "1.5 L",
      "notes": "low-sodium"
    },
    {
