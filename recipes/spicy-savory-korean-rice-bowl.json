    },
    {
      "name": "Soy sauce",
      "amount": "1 tsp",
      "notes": "low-sodium"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a small saucepan, heat the gochujang over low heat.",
    "In a large bowl, combine the cooked mixed grain rice, bulgogi beef, kimchi, and soy sauce.",
    "Stir in the heated gochujang and mix well.",
    "Transfer the rice mixture to a ramekin.",
    "Top the rice with shredded mozzarella cheese.",
    "Bake the rice bowl in the preheated oven for 10 minutes, or until the cheese is melted and bubbly.",
    "Garnish with chopped green onions and toasted sesame seeds.",
    "Serve immediately and enjoy."
