      "name": "tomatoes",
      "amount": "2 large",
      "notes": "sliced"
    },
    {
      "name": "red chilli powder",
      "amount": "1/4 teaspoon",
      "notes": "adjust to taste for spiciness"
    },
    {
      "name": "paleo-friendly soy sauce",
      "amount": "1 tablespoon",
      "notes": ""
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "garlic cloves",
      "amount": "3, minced",
      "notes": ""
    },
    {
      "name": "pine nuts",
      "amount": "1/4 cup, toasted and crushed",
      "notes": ""
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": ""
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add the minced garlic and cook for about 30 seconds until fragrant but not browned.",
    "Add the sliced tomatoes, red chilli powder, paleo-friendly soy sauce, and lemon juice. Stir well to combine all ingredients and bring to a simmer.",
    "Cook for about 5-7 minutes, or until the tomatoes are tender and slightly caramelized.",
    "Fold in the toasted pine nuts just before serving.",
    "Garnish with fresh basil leaves if desired."
  ],
