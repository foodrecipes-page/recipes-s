{
  "title": "Sweet Crispy Egyptian Tomato Stir-fry",
  "description": "A festive egyptian dish featuring tender tomatoes sweetened with red chilli powder and cooked to crispy perfection in a Paleo-friendly stir-fry.",
  "cuisine": "Egyptian",
  "diet": [
    "paleo"
  ],
