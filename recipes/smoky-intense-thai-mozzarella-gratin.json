      "name": "mature thai chilies",
      "amount": "2-3"
    },
    {
      "name": "kombu seaweed",
      "amount": "1 sheet"
    },
    {
      "name": "mozzarella balls",
      "amount": "12",
      "notes": "preferably buffalo mozzarella"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium, thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "palm sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "fresh cilantro leaves",
      "amount": "1/4 cup, chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "sugar",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "preheat the oven to 400f (200c).",
    "rehydrate kombu seaweed by soaking it in cold water for at least 4 hours.",
    "drain the kombu and blend it with 1/2 cup of cold water to create a cold extract.",
    "in a large pan, heat 2 tablespoons of coconut oil over medium heat.",
    "add onion and cook until softened, about 5 minutes.",
    "add garlic and cook for 1 minute.",
    "add palm sugar, fish sauce, salt, sugar, and black pepper. stir to combine.",
    "add the cold kombu extract and stir to combine.",
    "place mozzarella balls in a baking dish and pour the onion mixture over them.",
    "cover the dish with aluminum foil and bake for 15 minutes.",
    "remove the foil and continue baking for an additional 5-7 minutes, or until the cheese is melted and bubbly.",
    "garnish with chopped cilantro leaves and serve immediately."
  ],
