{
  "title": "smoky intense thai mozzarella gratin",
  "description": "a rich thai-inspired gratin dish featuring smoky flavors and gooey mozzarella cheese",
  "cuisine": "thai",
  "diet": [
    "keto"
  ],
  "meal": "dinner",
  "ingredients": [
