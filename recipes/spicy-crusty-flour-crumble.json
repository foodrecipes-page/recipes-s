{
  "title": "Spicy Crusty Flour Crumble",
  "description": "A flavorful and flaky dish perfect for a sick-day meal, featuring malai to add richness and spice.",
  "cuisine": "Indian",
  "diet": [
    "kosher-friendly"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "all-purpose flour",
      "amount": "1 cup"
    },
    {
      "name": "melted ghee or oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "pepper powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "cumin seeds",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "mustard seeds",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "ginger paste",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic paste",
      "amount": "1 tablespoon"
    },
    {
      "name": "curry leaves",
      "amount": "a few"
    },
    {
      "name": "saffron strands",
      "amount": "2-3"
    },
    {
      "name": "milk (optional)",
      "amount": "50 ml"
    }
  ],
  "instructions": [
    "Mix all the ingredients in a bowl, except for milk.",
    "Fold the mixture into itself to form a crumb consistency. Add more flour or ghee if needed to achieve desired texture.",
    "If using milk, add it and knead well until you have a smooth dough.",
    "Preheat oven to 180°C (350°F).",
    "Transfer the dough onto a greased baking tray or sheet.",
    "Use your fingers to press down on the crumble in an even layer. Leave some raised edges for added texture.",
    "Bake for about 15-20 minutes, checking occasionally until golden brown and crispy.",
    "Remove from oven and let it cool before slicing into pieces."
  ],
