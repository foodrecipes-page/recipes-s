      "amount": "4-6",
      "notes": "Mince finely"
    },
    {
      "name": "Black olives",
      "amount": "1 cup pitted",
      "notes": ""
    },
    {
      "name": "Minced onion",
      "amount": "1 small",
      "notes": ""
    },
    {
      "name": "Panko breadcrumbs",
      "amount": "1/2 cup",
      "notes": "Optional for a gooier texture"
    },
    {
      "name": "Spices (optional)",
      "amount": "To taste",
      "notes": "Cayenne pepper, paprika, cumin"
    }
  ],
  "instructions": [
    "Heat olive oil in a pan over medium heat.",
    "Add minced garlic and cook until fragrant, about 2 minutes.",
    "Stir in the black olives and minced onion. Cook for another 5-7 minutes until softened.",
    "Sprinkle panko breadcrumbs over the mixture (if using). Stir well to coat evenly.",
    "Season with spices of your choice. Taste test; adjust seasoning accordingly.",
    "Continue cooking until all liquid is absorbed, about 2 more minutes.",
    "Serve hot and enjoy!"
