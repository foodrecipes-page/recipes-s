{
  "title": "Smoky Spicy Pilchards Ceviche",
  "description": "A light and show-off British dish featuring pilchards marinated in a blend of spices and smoke for a unique twist on traditional ceviche.",
  "cuisine": "British",
  "diet": null,
  "meal": "snack",
  "ingredients": [
    {
      "name": "Pilchards",
      "amount": "250g (1 can)"
    },
    {
      "name": "Lime juice",
      "amount": "3 tbsp"
    },
    {
      "name": "Fresh lime zest",
      "amount": "1 tsp"
    },
    {
      "name": "Red chilli, finely chopped",
      "amount": "1-2"
    },
    {
      "name": "Garlic, minced",
      "amount": "2 cloves"
    },
    {
      "name": "Cumin seeds",
      "amount": "1 tsp"
    },
    {
      "name": "Smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "Salt",
      "amount": "Pinch"
    },
    {
      "name": "Black pepper",
      "amount": "A few grinds"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Sugar",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Place the pilchards in a bowl and add lime juice, red chilli, garlic, cumin seeds, smoked paprika, salt, and black pepper. Mix well.",
    "In a separate bowl, whisk together olive oil and sugar until smooth. Add to the marinade and mix again.",
    "Cover with cling film and marinate at room temperature for 10-20 minutes or refrigerate overnight.",
    "Serve chilled over crushed ice."
  ],
