{
  "title": "Spicy Silky Raw-Friendly Slovakian Sushi Rice Stir-fry",
  "description": "This spicy and silky raw-friendly dish features sushi rice cooked with a tadka base for a monsoon-inspired flavor profile.",
  "cuisine": "Slovakian",
