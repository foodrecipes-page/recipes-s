  "ingredients": [
    {
      "name": "canned tuna",
      "amount": "12 oz",
      "notes": "drained and flaked"
    },
    {
      "name": "pita bread",
      "amount": "4 cups",
      "notes": "torn into bite-sized pieces"
    },
    {
      "name": "mixed greens",
      "amount": "2 cups"
    },
    {
      "name": "cherry tomatoes",
      "amount": "1 cup",
      "notes": "halved"
    },
    {
      "name": "cucumber",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "red onion",
      "amount": "1/2 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "date syrup",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Preheat the air fryer to 400 degrees Fahrenheit",
    "Toss the pita bread pieces with 1/2 tbsp of olive oil and cook in the air fryer for 5 minutes",
    "In a large bowl, combine the mixed greens, cherry tomatoes, cucumber, and red onion",
    "In a small bowl, whisk together the date syrup and lemon juice",
    "Add the cooked pita bread pieces to the bowl with the mixed greens and toss to combine",
    "Add the flaked tuna to the bowl and toss to combine",
    "Drizzle the date syrup and lemon juice mixture over the top of the salad and toss to combine",
    "Season with salt and pepper to taste",
    "Serve immediately and enjoy"
  ],
