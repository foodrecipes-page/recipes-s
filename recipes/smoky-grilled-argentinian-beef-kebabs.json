  "title": "Smoky Grilled Argentinian Beef Kebabs",
  "description": "A savory and festive Argentinian dish featuring chewy grilled beef, perfect for special occasions or weeknight meals.",
  "cuisine": "Argentinian",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Flank steak",
      "amount": "500g",
      "notes": "preferably grass-fed"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp",
      "notes": "for brushing kebabs"
    },
    {
      "name": "Garlic granules",
      "amount": "1 tsp",
      "notes": "or 2-3 minced cloves"
    },
    {
      "name": "Salt",
      "amount": "1 tsp",
      "notes": "preferably sea salt"
    },
    {
      "name": "Black pepper",
      "amount": "0.5 tsp",
      "notes": "freshly ground"
    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped, for garnish"
    },
    {
      "name": "Lemon wedges",
      "amount": "4",
      "notes": "for serving"
    }
  ],
  "instructions": [
    "Preheat the robata grill to medium-high heat.",
    "Thread the flank steak onto metal or bamboo skewers, leaving a small space between each piece.",
    "Brush the kebabs with olive oil and sprinkle with garlic granules, salt, and black pepper.",
    "Grill the kebabs for 8-10 minutes per side, or until they reach your desired level of doneness.",
    "Transfer the kebabs to a cutting board and let them rest for 5 minutes.",
    "Slice the kebabs into thin strips and garnish with chopped parsley.",
    "Serve the kebabs hot with lemon wedges on the side."
  ],
