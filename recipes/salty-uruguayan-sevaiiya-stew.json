      "name": "500g sevaiiya",
      "amount": "1 bag"
    },
    {
      "name": "2 tbsp olive oil",
      "notes": "For cooking the sevaiiya and vegetables"
    },
    {
      "name": "1 onion, finely chopped",
      "amount": null
    },
    {
      "name": "3 cloves garlic, minced",
      "amount": null
    },
    {
      "name": "2 medium potatoes, peeled and cubed",
      "amount": null
    },
    {
      "name": "1 bell pepper, sliced",
      "amount": null
    },
    {
      "name": "1 can kidney beans, drained and rinsed",
      "amount": null
    },
    {
      "name": "3 cups vegetable broth",
      "amount": null
    },
    {
      "name": "1 tsp cumin seeds",
      "amount": null
    },
    {
      "name": "1/2 tsp coriander powder",
      "amount": null
    },
    {
      "name": "1 bay leaf",
      "notes": "To infuse the flavor"
    },
    {
      "name": "Salt to taste",
      "amount": null
    }
  ],
  "instructions": [
    "Heat olive oil in a large pot over medium heat.",
    "Add onions and garlic, sauté until softened.",
    "Stir in cubed potatoes and sliced bell pepper. Cook for about 5 minutes.",
    "Roughly chop the sevaiiya and add to the pot with kidney beans and bay leaf.",
    "Pour in vegetable broth, bring to a boil, then reduce heat to low.",
    "Simmer gently for at least 30 minutes or until sevaiiya is tender.",
    "Season with salt and cumin coriander powder to taste."
