      "name": "uni",
      "amount": "1/2 cup",
      "notes": "fresh, sashimi-grade"
    },
    {
      "name": "bread",
      "amount": "4 slices",
      "notes": "crusty, day-old"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon",
      "notes": "smoked"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "Slice the bread into 1/2-inch thick slices and toast until crispy.",
    "In a small bowl, mix together the olive oil, garlic, paprika, salt, and black pepper.",
    "Brush the toasted bread slices with the garlic-paprika oil mixture.",
    "Top each bread slice with a spoonful of uni.",
    "Drizzle the lemon juice over the uni.",
    "Serve immediately and enjoy.",
    "Garnish with chopped fresh parsley or chives, if desired.",
    "Store any leftovers in an airtight container in the refrigerator for up to one day."
  ],
