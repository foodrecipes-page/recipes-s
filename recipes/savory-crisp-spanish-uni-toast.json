{
  "title": "Savory Crisp Spanish Uni Toast",
  "description": "A post-workout Spanish dish featuring uni and toast, with a focus on umami flavor and crispy texture, suitable for a shojin-friendly diet. This dish is inspired by Galician cuisine.",
  "cuisine": "Spanish",
