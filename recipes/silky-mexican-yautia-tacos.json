      "name": "yautia",
      "amount": "2 large",
      "notes": "also known as malanga or taro root"
    },
    {
      "name": "corn tortillas",
      "amount": "8-10",
      "notes": "preferably day-old tortillas"
    },
    {
      "name": "vegetable oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "chipotle peppers in adobo sauce",
      "amount": "2-3"
    },
    {
      "name": "fermented salsa",
      "amount": "1/2 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "cilantro",
      "amount": "chopped, for garnish"
    }
  ],
  "instructions": [
    "Peel and dice the yautia into 1-inch cubes.",
    "Heat the vegetable oil in a large skillet over medium heat.",
    "Add the diced onion and cook until translucent, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the diced yautia and cook until tender, about 10-12 minutes.",
    "Add the chipotle peppers and fermented salsa, stir to combine.",
    "Season with salt to taste.",
    "Warm the corn tortillas by wrapping them in a damp paper towel and microwaving for 20-30 seconds.",
    "Assemble the tacos by spooning the yautia mixture onto a tortilla and garnishing with chopped cilantro and a squeeze of lime juice.",
    "Serve immediately and enjoy!"
  ],
