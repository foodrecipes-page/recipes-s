    },
    {
      "name": "Fresh cilantro",
      "amount": "1 tbsp",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat coconut oil in a large pot over medium heat.",
    "Add chopped onion and sauté until translucent, about 3 minutes.",
    "Stir in minced garlic, grated ginger, dried chilies, curry powder, and smoked paprika; cook for 1 minute until fragrant.",
    "Add cauliflower florets and cook, stirring, for 5 minutes to start browning.",
    "Pour in fermented coconut milk and vegetable stock; bring to a gentle simmer.",
    "Reduce heat to low, cover, and let the curry steam for 15–20 minutes until cauliflower is tender and sauce is thickened.",
    "Fold in cooked chickpeas, season with salt and pepper to taste, and simmer uncovered for an additional 5 minutes.",
    "Serve hot, garnished with fresh cilantro and a squeeze of lime if desired."
  ],
