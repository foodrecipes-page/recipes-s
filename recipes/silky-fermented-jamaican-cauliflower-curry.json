{
  "title": "Silky Fermented Jamaican Cauliflower Curry",
  "description": "A probiotic-rich, silky cauliflower curry infused with Jamaican spices and fermented coconut milk, perfect for a protein-packed weeknight dinner.",
  "cuisine": "Jamaican",
  "diet": [
    "high-protein"
  ],
