      "amount": "200 ml"
    },
    {
      "name": "Chickpeas, cooked",
      "amount": "150 g"
    },
    {
      "name": "Onion, finely chopped",
      "amount": "1 medium (150 g)"
    },
    {
      "name": "Garlic cloves",
      "amount": "2",
      "notes": "minced"
    },
    {
