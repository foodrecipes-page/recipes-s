  "ingredients": [
    {
      "name": "Heavy Cream",
      "amount": "1 1/2 cups",
      "notes": ""
    },
    {
      "name": "Caramel Sauce",
      "amount": "1/2 cup",
      "notes": "Make sure it's Whole30-friendly."
    },
    {
      "name": "Fresh Mint",
      "amount": "1/4 cup",
      "notes": "Chopped."
    },
    {
      "name": "Lime Juice",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "Honey",
      "amount": "2 tablespoons",
      "notes": "Raw, unfiltered."
    },
    {
      "name": "Gelatin",
      "amount": "1 tablespoon",
      "notes": "Unflavored, unsweetened."
    },
    {
      "name": "Saffron Threads",
      "amount": "1/4 teaspoon",
      "notes": "Soaked in 1 tablespoon hot water."
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon",
      "notes": ""
    },
    {
      "name": "Pistachios",
      "amount": "1/4 cup",
      "notes": "Chopped."
    },
    {
      "name": "Fresh Pomegranate Seeds",
      "amount": "2 tablespoons",
      "notes": "Optional."
    },
    {
      "name": "Cardamom",
      "amount": "1/4 teaspoon",
      "notes": "Ground."
    }
  ],
  "instructions": [
    "In a small bowl, sprinkle the gelatin over 1/4 cup cold water and let it sit for 5 minutes.",
    "In a medium saucepan, combine the heavy cream, caramel sauce, lime juice, honey, and saffron mixture. Heat over medium heat, stirring occasionally, until the mixture is hot but not boiling.",
    "Remove the saucepan from the heat and add the gelatin mixture, stirring until it's fully dissolved.",
    "Add the chopped fresh mint and stir to combine.",
    "Pour the mixture into small individual serving cups or ramekins. Refrigerate for at least 4 hours, or until set.",
    "Just before serving, top each pudding with chopped pistachios and a few fresh pomegranate seeds, if using.",
    "Garnish with a sprinkle of ground cardamom, if desired.",
    "Serve chilled.",
    "Cover and refrigerate any leftovers for up to 3 days."
  ],
