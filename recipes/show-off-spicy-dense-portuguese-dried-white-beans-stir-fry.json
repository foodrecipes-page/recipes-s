      "name": "1 can of (240g) dried white beans",
      "amount": "",
      "notes": "Soaked overnight"
    },
    {
      "name": "3 cloves garlic, minced",
      "amount": ""
    },
    {
      "name": "1 small onion, finely chopped",
      "amount": ""
    },
    {
      "name": "1 red bell pepper, sliced",
      "amount": ""
    },
    {
      "name": "2 tbsp olive oil",
      "amount": ""
    },
    {
      "name": "1 tsp smoked paprika",
      "amount": ""
    },
    {
      "name": "1/2 tsp cayenne pepper",
      "amount": ""
    },
    {
      "name": "Salt to taste",
      "amount": ""
    },
    {
      "name": "Fresh parsley, chopped (for garnish)",
      "amount": ""
    }
  ],
  "instructions": [
    "Heat oil in a large skillet over medium heat. Add minced garlic and onion; sauté for about 2 minutes.",
    "Add red bell pepper and cook until softened, about 5 minutes.",
    "Drain soaked white beans, reserving any liquid. Add to the skillet with remaining ingredients and stir well. Let it simmer for approximately 10 minutes.",
    "Season with smoked paprika and cayenne pepper, then adjust salt based on preference.",
    "Serve hot garnished with fresh parsley."
