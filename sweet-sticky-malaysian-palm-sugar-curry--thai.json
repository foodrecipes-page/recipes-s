{
  "slug": "sweet-sticky-malaysian-palm-sugar-curry--thai",
  "title": "Thai Sweet Palm Curry",
  "description": "A traditional Thai curry made with palm sugar, curry paste, and a variety of spices. Serve with steamed rice for a delicious and flavorful meal.",
  "cuisine": "thai",
  "diet": [
    "vegetarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "Palm sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "Thai red curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "Malaysian sweet potatoes",
      "amount": "2 medium"
    },
    {
      "name": "Sticky rice",
      "amount": "2 cups"
    },
    {
      "name": "Coconut milk",
      "amount": "1 can"
    },
    {
      "name": "Water",
      "amount": "1 cup"
    },
    {
      "name": "Salt",
      "amount": "to taste"
    },
    {
      "name": "Curry leaves",
      "amount": "handful"
    },
    {
      "name": "Fresh cilantro",
      "amount": "chopped (optional)"
    }
  ],
  "instructions": [
    {
      "step": 1,
      "text": "Heat oil in a pan over medium heat. Add curry leaves and let it infuse for a minute."
    },
    {
      "step": 2,
      "text": "Add curry paste and sauté until fragrant. Add palm sugar and stir until dissolved."
    },
    {
      "step": 3,
      "text": "Add sweet potatoes and stir to coat with the curry paste mixture."
    },
    {
      "step": 4,
      "text": "Pour in coconut milk and water. Stir to combine."
    },
    {
      "step": 5,
      "text": "Bring the mixture to a boil, then reduce heat to low and simmer for 15-20 minutes or until the sweet potatoes are tender."
    },
    {
      "step": 6,
      "text": "Season with salt to taste."
    },
    {
      "step": 7,
      "text": "Serve the curry over sticky rice and garnish with chopped cilantro if desired."
    }
  ],
