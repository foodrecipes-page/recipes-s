      "name": "Australian lamb",
      "amount": "1 pound",
      "notes": "Cut into 1-inch cubes"
    },
    {
      "name": "Sour plum sauce",
      "amount": "1/4 cup",
      "notes": "See note for homemade version"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons",
      "notes": "For brushing skewers"
    },
    {
      "name": "Garlic",
      "amount": "2 cloves",
      "notes": "Minced"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tablespoons",
      "notes": "Freshly squeezed"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon",
      "notes": "To taste"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon",
      "notes": "To taste"
    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "Chopped (optional)"
    }
  ],
  "instructions": [
    "Preheat grill to medium-high heat.",
    "Thread lamb cubes onto skewers, leaving a little space between each piece.",
    "In a small bowl, whisk together sour plum sauce, olive oil, garlic, lemon juice, salt, and black pepper.",
    "Brush the sauce mixture onto both sides of the lamb cubes.",
    "Grill the skewers for 8-10 minutes, turning occasionally, or until the lamb reaches an internal temperature of 145°F (63°C).",
    "Let the skewers rest for 2-3 minutes before serving.",
    "Garnish with chopped parsley, if desired."
  ],
